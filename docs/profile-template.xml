<!-- Maven Profile Template for Modules -->
<!--
  Questo file serve come template per creare profile.xml nei moduli.
  Copia questo template nella root del tuo modulo e personalizzalo.
-->

<!-- [MODULE:nomemodulo] -->
<profile>
    <id>module-nomemodulo</id>
    <activation>
        <file>
            <!-- Il profile si attiva quando il tracker module.json esiste -->
            <exists>src/main/resources/modules/nomemodulo/module.json</exists>
        </file>
    </activation>
    <dependencies>
        <!-- Esempio: dipendenza per JWT -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
            <version>0.12.3</version>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <version>0.12.3</version>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <version>0.12.3</version>
            <scope>runtime</scope>
        </dependency>

        <!-- Esempio: dipendenza per Apache Commons -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
            <version>3.14.0</version>
        </dependency>

        <!-- Aggiungi qui altre dipendenze necessarie al modulo -->
    </dependencies>
</profile>
<!-- [/MODULE:nomemodulo] -->

<!--
  ISTRUZIONI:

  1. Sostituisci "nomemodulo" con il nome effettivo del tuo modulo (in 3 posizioni)
  2. Aggiungi/rimuovi le dipendenze Maven necessarie
  3. Salva come "profile.xml" nella root del modulo

  MARKER OBBLIGATORI:
  - <!-- [MODULE:nomemodulo] --> all'inizio
  - <!-- [/MODULE:nomemodulo] --> alla fine
  Questi marker sono usati da "cmd module remove" per identificare e rimuovere il profile.

  ATTIVAZIONE AUTOMATICA:
  Il tag <activation><file><exists> fa sì che Maven attivi automaticamente
  questo profile quando il modulo è installato (tracker presente) e lo disattivi
  quando il modulo è rimosso (tracker assente).

  GESTIONE AUTOMATICA:
  - cmd module export: estrae questo profile dal pom.xml
  - cmd module import: inserisce questo profile nel pom.xml
  - cmd module remove: rimuove questo profile dal pom.xml
-->
