            return 0
        fi

        local SCRIPTS
        SCRIPTS=$(find "$TEST_DIR" -maxdepth 1 -type f -name "*.sh" 2>/dev/null | sort)

        if [ -z "$SCRIPTS" ]; then
            echo "No test scripts available for module '$MODULE_NAME'"
            return 0
        fi

        echo "Available test scripts for module '$MODULE_NAME':"
        echo "$SCRIPTS" | while read -r SCRIPT; do
            local BASENAME
            BASENAME=$(basename "$SCRIPT" .sh)
            echo "  - $BASENAME"
        done
        return 0
    fi

    # Comportamento originale: esegui lo script
    local SCRIPT="$TEST_DIR/${COMMAND}.sh"
    [ -f "$SCRIPT" ] || error "Script not found: module/${MODULE_NAME}/test/${COMMAND}.sh"

    bash "$SCRIPT" "$@"
}
# ============================================================================
# Snapshot Operations
# ============================================================================

# Legge la passphrase: da SNAP_PASSPHRASE (env) o interattivamente da /dev/tty
_snap_passphrase() {
    local PROMPT="$1"
    if [ -n "${SNAP_PASSPHRASE:-}" ]; then
        printf '%s' "$SNAP_PASSPHRASE"
    else
        local PASS
        printf '%s' "$PROMPT" >&2
        read -rs PASS </dev/tty
        printf '\n' >&2
        printf '%s' "$PASS"
    fi
}

snap_create() {
    load_env

    command -v gpg >/dev/null 2>&1 || error "gpg non trovato. Installare con: apt-get install gnupg"

    local SNAP_DIR="$WORKSPACE/snapshots"
    local SNAP_TMP="$SNAP_DIR/snapshot"
    local SNAP_TAR="$SNAP_DIR/snapshot.tar.gz"
    local SNAP_OUT="$SNAP_DIR/snapshot.tar.gz.gpg"

    # Chiedi passphrase prima di fare qualsiasi lavoro
    local PASSPHRASE
    PASSPHRASE=$(_snap_passphrase "Passphrase: ")
    [ -n "$PASSPHRASE" ] || error "Passphrase obbligatoria"

    # Conferma passphrase solo in modalità interattiva
    if [ -z "${SNAP_PASSPHRASE:-}" ]; then
        local PASSPHRASE2
        PASSPHRASE2=$(_snap_passphrase "Conferma passphrase: ")
        [ "$PASSPHRASE" = "$PASSPHRASE2" ] || error "Le passphrase non corrispondono"
    fi

    rm -rf "$SNAP_TMP"
    mkdir -p "$SNAP_TMP"

    info "[snap] Creo snapshot..."
    printf '\n'

    # 1. .env
    if [ -f "$WORKSPACE/.env" ]; then
        cp "$WORKSPACE/.env" "$SNAP_TMP/.env"
        success "  ✓ .env"
    else
        warn "  ⚠ .env non trovato"
    fi

    # 2. .vscode/settings.json
    if [ -f "$WORKSPACE/.vscode/settings.json" ]; then
        mkdir -p "$SNAP_TMP/.vscode"
        cp "$WORKSPACE/.vscode/settings.json" "$SNAP_TMP/.vscode/settings.json"
        success "  ✓ .vscode/settings.json"
    fi

    # 4. config/
    if [ -d "$WORKSPACE/config" ]; then
        cp -r "$WORKSPACE/config" "$SNAP_TMP/config"
        local CONFIG_COUNT
        CONFIG_COUNT=$(find "$WORKSPACE/config" -type f | wc -l)
        success "  ✓ config/ → $CONFIG_COUNT file"
    else
        warn "  ⚠ config/ non trovata"
    fi

    # 5. pg_dump completo (schema + dati)
    if [ "${PGSQL_ENABLED:-false}" = "true" ]; then
        local PG_HOST PG_PORT
        PG_HOST="${PGSQL_HOST:-postgres}"
        PG_PORT="${PGSQL_PORT:-5432}"
        info "  [snap] Esporto database $PGSQL_NAME..."
        PGPASSWORD="$PGSQL_ROOT_PASSWORD" pg_dump \
            -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" \
            --no-owner --no-acl \
            "$PGSQL_NAME" > "$SNAP_TMP/database.sql" 2>/dev/null || true
        if [ -s "$SNAP_TMP/database.sql" ]; then
            local DB_SIZE
            DB_SIZE=$(du -sh "$SNAP_TMP/database.sql" | cut -f1)
            success "  ✓ database.sql → $DB_SIZE"
        else
            rm -f "$SNAP_TMP/database.sql"
            warn "  ⚠ database export skipped (vuoto o fallito)"
        fi
    else
        info "  [snap] PostgreSQL disabilitato — database saltato"
    fi

    # Comprimi
    printf '\n'
    info "[snap] Comprimo..."
    tar -czf "$SNAP_TAR" -C "$SNAP_DIR" "snapshot"
    rm -rf "$SNAP_TMP"

    # Cifra con GPG simmetrico AES256
    info "[snap] Cifro con GPG (AES256)..."
    rm -f "$SNAP_OUT"
    printf '%s' "$PASSPHRASE" | gpg --batch --yes \
        --symmetric --cipher-algo AES256 \
        --passphrase-fd 0 \
        --output "$SNAP_OUT" \
        "$SNAP_TAR"
    rm -f "$SNAP_TAR"

    printf '\n'
    success "Snapshot creato: snapshots/snapshot.tar.gz.gpg"
    info "Ripristina con:  cmd snap restore"
    printf '\n'
}

snap_restore() {
    load_env

    command -v gpg >/dev/null 2>&1 || error "gpg non trovato. Installare con: apt-get install gnupg"

    local DB_ONLY=false
    local CONFIG_ONLY=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --db-only)     DB_ONLY=true; shift ;;
            --config-only) CONFIG_ONLY=true; shift ;;
            *) error "Opzione non riconosciuta: $1. Usa: --db-only, --config-only" ;;
        esac
    done

    local SNAP_DIR="$WORKSPACE/snapshots"
    local SNAP_OUT="$SNAP_DIR/snapshot.tar.gz.gpg"
    local SNAP_TAR="$SNAP_DIR/snapshot.tar.gz"
    local SNAP_TMP="$SNAP_DIR/snapshot"

    [ -f "$SNAP_OUT" ] || error "Snapshot non trovato: snapshots/snapshot.tar.gz.gpg. Creare con: cmd snap"

    local PASSPHRASE
    PASSPHRASE=$(_snap_passphrase "Passphrase: ")
    [ -n "$PASSPHRASE" ] || error "Passphrase obbligatoria"

    # Decifra
    info "[snap] Decifro snapshot..."
    rm -f "$SNAP_TAR"
    printf '%s' "$PASSPHRASE" | gpg --batch --yes \
        --passphrase-fd 0 \
        --output "$SNAP_TAR" \
        --decrypt "$SNAP_OUT" 2>/dev/null \
        || error "Decifratura fallita — passphrase errata?"

    # Estrai
    rm -rf "$SNAP_TMP"
    tar -xzf "$SNAP_TAR" -C "$SNAP_DIR"
    rm -f "$SNAP_TAR"

    printf '\n'
    info "[snap] Ripristino in corso..."
    printf '\n'

    # config/, .env, .vscode/settings.json (saltati solo con --db-only)
    if ! $DB_ONLY; then
        if [ -f "$SNAP_TMP/.env" ]; then
            cp "$SNAP_TMP/.env" "$WORKSPACE/.env"
            success "  ✓ .env ripristinato"
        fi
        if [ -f "$SNAP_TMP/.vscode/settings.json" ]; then
            mkdir -p "$WORKSPACE/.vscode"
            cp "$SNAP_TMP/.vscode/settings.json" "$WORKSPACE/.vscode/settings.json"
            success "  ✓ .vscode/settings.json ripristinato"
        fi
        if [ -d "$SNAP_TMP/config" ]; then
            mkdir -p "$WORKSPACE/config"
            cp -r "$SNAP_TMP/config/." "$WORKSPACE/config/"
            success "  ✓ config/ ripristinata"
        fi
    fi

    # database (saltato solo con --config-only)
    if ! $CONFIG_ONLY; then
        if [ -f "$SNAP_TMP/database.sql" ] && [ "${PGSQL_ENABLED:-false}" = "true" ]; then
            local PG_HOST PG_PORT
            PG_HOST="${PGSQL_HOST:-postgres}"
            PG_PORT="${PGSQL_PORT:-5432}"

            warn "  Questo sovrascriverà tutti i dati esistenti in $PGSQL_NAME!"
            confirm "  Continuare?" || { rm -rf "$SNAP_TMP"; exit 0; }

            export PGPASSWORD="$PGSQL_ROOT_PASSWORD"
            # Termina connessioni attive e ricrea il database
            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
                -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$PGSQL_NAME' AND pid <> pg_backend_pid();" \
                2>/dev/null || true
            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
                -c "DROP DATABASE IF EXISTS $PGSQL_NAME;" 2>/dev/null || true
            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
                -c "CREATE DATABASE $PGSQL_NAME;" \
                || { rm -rf "$SNAP_TMP"; error "Impossibile creare il database"; }
            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" \
                -c "GRANT ALL ON SCHEMA public TO \"$PGSQL_USER\";" 2>/dev/null || true

            info "  [snap] Importo database $PGSQL_NAME..."
            PGPASSWORD="$PGSQL_ROOT_PASSWORD" psql \
                -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" \
                -d "$PGSQL_NAME" \
                -f "$SNAP_TMP/database.sql" \
                || { rm -rf "$SNAP_TMP"; error "Ripristino database fallito"; }

            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" \
                -c "GRANT ALL ON ALL TABLES IN SCHEMA public TO \"$PGSQL_USER\"; GRANT ALL ON ALL SEQUENCES IN SCHEMA public TO \"$PGSQL_USER\";" \
                2>/dev/null || true

            local DB_SIZE
            DB_SIZE=$(du -sh "$SNAP_TMP/database.sql" | cut -f1)
            success "  ✓ database ripristinato ($DB_SIZE)"
        else
            if [ "${PGSQL_ENABLED:-false}" != "true" ]; then
                info "  [snap] PostgreSQL disabilitato — database saltato"
            elif [ ! -f "$SNAP_TMP/database.sql" ]; then
                info "  [snap] Nessun dump database nello snapshot"
            fi
        fi
    fi

    rm -rf "$SNAP_TMP"

    printf '\n'
    success "Ripristino completato"
    printf '\n'
}

# Benchmark Operations
# ============================================================================

bench_run() {
    load_env

    # Check if siege is installed
    command -v siege >/dev/null 2>&1 || \
        error "siege not found. Run './install.sh' to rebuild the dev container with siege."

    # Create bench directory if it doesn't exist
    local BENCH_DIR="$WORKSPACE/bench"
    mkdir -p "$BENCH_DIR"

    # Generate timestamp for log file
    local TIMESTAMP
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    local LOG_FILE="$BENCH_DIR/siege-${TIMESTAMP}.log"

    # Parse arguments to detect URL and check for -c/-r/-t options
    local URL=""
    local HAS_CONCURRENCY=false
    local HAS_REPS_OR_TIME=false
    local SIEGE_ARGS=()

    while [ $# -gt 0 ]; do
        case "$1" in
            -u|--url)
                [ -n "$2" ] || error "Option -u requires a URL"
                URL="$2"
                shift 2
                ;;
            -c|--concurrent)
                HAS_CONCURRENCY=true
                SIEGE_ARGS+=("$1" "$2")
                shift 2
                ;;
            -r|--reps|-t|--time)
                HAS_REPS_OR_TIME=true
                SIEGE_ARGS+=("$1" "$2")
                shift 2
                ;;
            -*)
                SIEGE_ARGS+=("$1")
                shift
                ;;
            http://*|https://*)
                # URL without -u option
                URL="$1"
                shift
                ;;
            *)
                SIEGE_ARGS+=("$1")
                shift
                ;;
        esac
    done

    # Add default -c 10 -r 100 if not specified
    if [ "$HAS_CONCURRENCY" = false ]; then
        SIEGE_ARGS=("-c" "10" "${SIEGE_ARGS[@]}")
    fi
    if [ "$HAS_REPS_OR_TIME" = false ]; then
        SIEGE_ARGS=("-r" "100" "${SIEGE_ARGS[@]}")
    fi

    # Add URL at the end if specified
    if [ -n "$URL" ]; then
        SIEGE_ARGS+=("$URL")
    fi

    info "Running siege benchmark..."
    info "Options: ${SIEGE_ARGS[*]}"
    info "Log file: bench/siege-${TIMESTAMP}.log"
    echo ""

    # Run siege with processed arguments, output to both stdout and log file
    siege "${SIEGE_ARGS[@]}" 2>&1 | tee "$LOG_FILE"

    local EXIT_CODE=${PIPESTATUS[0]}

    if [ $EXIT_CODE -eq 0 ]; then
        success "Benchmark completed → bench/siege-${TIMESTAMP}.log"
    else
        warn "Benchmark exited with code $EXIT_CODE → bench/siege-${TIMESTAMP}.log"
    fi

    return $EXIT_CODE
}

# ============================================================================
# Command parsing
# ============================================================================

case "$1" in
    app)
        case "$2" in
            build)   app_build ;;
            run)     app_run ;;
            debug)   app_debug ;;
            start)   app_start ;;
            stop)    app_stop "${@:3}" ;;
            restart) app_restart ;;
            status)  app_status ;;
            clean)   app_clean ;;
            *) error "Unknown app command: $2. Use: build, clean, run, debug, start, stop, restart, status" ;;
        esac
        ;;
    gui)
        case "$2" in
            build) vite_build ;;
            run)   vite_run ;;
            clean) vite_clean ;;
            *) error "Unknown gui command: $2. Use: build, clean, run" ;;
        esac
        ;;
    git)
        GIT_CMD="$2"
        REPO_PATH=""
        BASE_BRANCH=""
        BRANCH_NAME=""
        shift 2

        while [ $# -gt 0 ]; do
            case "$1" in
                -r|--repo)   REPO_PATH="$2";   shift 2 ;;
                -b|--branch) BRANCH_NAME="$2"; shift 2 ;;
                -f|--from)   BASE_BRANCH="$2"; shift 2 ;;
                *) error "Unknown option: $1" ;;
            esac
        done

        case "$GIT_CMD" in
            init)   git_init ;;
            push)   git_push "$REPO_PATH" ;;
            pull)   git_pull "$REPO_PATH" ;;
            sync)   git_sync "$REPO_PATH" ;;
            fetch)  git_fetch ;;
            branch) git_branch "$BRANCH_NAME" "$REPO_PATH" "$BASE_BRANCH" ;;
            merge)  git_merge "$BRANCH_NAME" "$REPO_PATH" ;;
            update) git_update "$REPO_PATH" ;;
            *) error "Unknown git command: $GIT_CMD. Use: init, push, pull, sync, fetch, branch, merge, update" ;;
        esac
        ;;
    db)
        shift 1
        if [ $# -eq 0 ]; then
            db_cli ""
        elif [ "$1" = "-f" ]; then
            [ -n "$2" ] || error "Option -f requires a file path"
            db_cli "$2"
        elif [ "$1" = "-c" ]; then
            [ -n "$2" ] || error "Option -c requires a SQL query"
            db_cli_query "$2"
        elif [ "$1" = "status" ]; then
            db_status
        elif [ "$1" = "reset" ]; then
            db_reset
        elif [ "$1" = "setup" ]; then
            db_setup
        else
            error "Unknown db option: $1. Use: db, db -c <sql>, db -f <file>, db status, db reset, db setup"
        fi
        ;;
    ngrok)
        case "$2" in
            run)    ngrok_run ;;
            start)  ngrok_start ;;
            stop)   ngrok_stop ;;
            status) ngrok_status ;;
            *) error "Unknown ngrok command: $2. Use: run, start, stop, status" ;;
        esac
        ;;
    bench)
        shift 1
        bench_run "$@"
        ;;
    module)
        case "$2" in
            export)    shift 2; module_export "$@" ;;
            install)   shift 2; module_install "$@" ;;
            dist)      shift 2; module_dist "$@" ;;
            uninstall) shift 2; module_remove "$@" ;;
            cli)       shift 2; module_cli "$@" ;;
            test)      shift 2; module_test "$@" ;;
            *) error "Unknown module command: $2. Use: export, install, dist, uninstall, cli, test" ;;
        esac
        ;;
    snap)
        case "$2" in
            restore) shift 2; snap_restore "$@" ;;
            create)  shift 2; snap_create "$@" ;;
            "")      shift;   snap_create "$@" ;;
            *) error "Comando snap non riconosciuto: $2. Usa: create, restore" ;;
        esac
        ;;
    -h|--help|help|"")
        show_help
        ;;
    *)
        error "Unknown command: $1. Use 'cmd --help' for usage."
        ;;
esac
