#!/bin/bash
set -e

WORKSPACE="/workspace"

# Helper functions
error()   { printf 'ERROR: %s\n' "$1" >&2; exit 1; }
info()    { printf 'INFO: %s\n' "$1"; }
warn()    { printf 'WARNING: %s\n' "$1" >&2; }
success() { printf '✓ SUCCESS: %s\n' "$1"; }

confirm() {
    printf '%s [y/N]: ' "$1"
    read -r answer || true
    case "$answer" in
        [Yy]|[Yy][Ee][Ss]) return 0 ;;
        *) return 1 ;;
    esac
}

load_env() {
    if [ -f "$WORKSPACE/.env" ]; then
        set -a
        . "$WORKSPACE/.env"
        set +a
    fi
}

show_help() {
    cat << 'HELPEOF'
Usage: cmd COMMAND [OPTIONS]

  app build                        Compile Java backend (Maven)
  app run                          Watch src/, compile on change, hot-restart
  app debug                        Watch src/, compile on change, hot-restart WITH remote debug on :5005
  app start                        Start in background
  app stop                         Stop background process
  app stop --force                 Force kill: termina per nome e per porta API (cleanup zombie/porta occupata)
  app restart                      Restart background process
  app status                       Show status
  app clean                        Remove compiled files (mvn clean → target/)

  gui build                        Build for production → src/main/resources/static/
  gui run                          Run Vite dev server (foreground, with API proxy)
  gui clean                        Clear build output (src/main/resources/static/)

  git init                         Inizializza repo locale, crea primo commit e pubblica su GitHub
  git push [-r <path>]             Stage, commit and push
  git pull [-r <path>]             Pull from remote
  git sync [-r <path>]             Pull + commit + push
  git fetch                        Initialize repo from remote (no .git required)
  git branch [-r <path>]           Show current branch name
  git branch -b <name> [-r <path>] [-f <base>]   Create branch from base (default: main)
  git merge -b <name> [-r <path>]  Merge branch to main and delete
  git update                       Update git config and remote URL from .env

  db                               Open interactive PostgreSQL CLI
  db -c <sql>                      Execute inline SQL query
  db -f <file>                     Execute SQL or CSV file
  db status                        Show app DB config, connection health and migrations
  db setup                         Create user and database from .env file
  db reset                         Reset database (drop and recreate)

  module install <path>              Install module from path relative to jms/module/ (folder or .tar.gz)
  module install <path> --force      Bypass missing dependency check
  module export --name <n> [-v x]    Export current project module to jms/module/<name>[-version]/
  module dist <path>                 Package module folder (relative to jms/module/) → dist/<name>-<version>.tar.gz
  module uninstall --name <name>     Remove installed module (blocked if other modules depend on it)
  module uninstall --name <name> --force  Bypass reverse dependency check
  module cli <module> <script> [OPTIONS]            Run jms/module/<module>/cli/<script>.sh [OPTIONS]

  ngrok run                        Start ngrok tunnel in foreground (Ctrl+C to stop)
  ngrok start                      Start ngrok tunnel in background
  ngrok stop                       Stop ngrok tunnel
  ngrok status                     Show ngrok status and public URL

  snap              Crea snapshot cifrato (config/ + .env + database) → snapshots/snapshot.tar.gz.gpg
  snap restore      Ripristina snapshot (opzioni: --db-only, --config-only)

  bench [options]                  Run siege benchmark (log to bench/siege-YYYYMMDD-HHMMSS.log)
                                     Default: -c 10 -r 100 (10 concurrent users, 100 reps each)
                                     -u <url>         Target URL
                                     -c <num>         Concurrent users (default: 10)
                                     -r <num>         Repetitions per user (default: 100)
                                     -t <time>        Duration (e.g., 30S, 5M, 1H)
                                     Other siege options are passed through

  -h, --help                       Show this help
HELPEOF
}

# ============================================================================
# App Operations (Java Undertow)
# ============================================================================

APP_JAR="$WORKSPACE/target/service.jar"
APP_PID_FILE="/run/service.pid"
APP_LOG_FILE="/app/logs/service.log"
NGROK_PID_FILE="/run/ngrok.pid"

app_is_running() {
    if [ -f "$APP_PID_FILE" ]; then
        local PID
        PID=$(cat "$APP_PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            return 0
        fi
        rm -f "$APP_PID_FILE"
    fi
    return 1
}


app_build() {
    load_env

    # Build frontend first
    info "Building frontend (Vite)..."
    vite_build

    info "Compiling Java backend (Maven)..."
    cd "$WORKSPACE"
    mvn --no-transfer-progress package -DskipTests
    success "Build completed → target/service.jar"
}
app_clean() {
    load_env
    info "Pulizia file di compilazione Java (Maven clean)..."
    cd "$WORKSPACE"
    mvn --no-transfer-progress clean
    success "Cartella target/ rimossa"
}

app_start() {
    load_env

    if app_is_running; then
        warn "Application is already running (PID: $(cat $APP_PID_FILE))"
        return 0
    fi

    [ -f "$APP_JAR" ] || error "JAR not found: $APP_JAR. Run 'cmd app build' first."

    info "Starting Java server in background..."
    cd "$WORKSPACE"
    nohup java -jar "$APP_JAR" > /dev/null 2>&1 &
    echo $! > "$APP_PID_FILE"

    sleep 1
    if app_is_running; then
        success "Application started (PID: $(cat $APP_PID_FILE))"
        info "Log: $APP_LOG_FILE"
        info "Internal: http://localhost:${API_PORT:-8080}/"
        info "External: http://localhost:${API_PORT_HOST:-2310}/"
    else
        error "Failed to start application. Check $APP_LOG_FILE"
    fi
}

app_stop() {
    local FORCE=false
    [ "${1:-}" = "--force" ] && FORCE=true

    if $FORCE; then
        load_env
        info "Cleanup forzato in corso..."
        local API_P="${API_PORT:-8080}"
        local VITE_P="${VITE_PORT:-5173}"
        local DEBUG_P="${DEBUG_PORT:-5005}"
        local PIDS PORT_PID KILLED
        PIDS=$(pgrep -f "dev.jms.app.App" 2>/dev/null || true)
        for P in "$API_P" "$VITE_P" "$DEBUG_P"; do
            PORT_PID=$(ss -tlnp "sport = :${P}" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1)
            PIDS=$(printf '%s\n%s' "$PIDS" "${PORT_PID:-}")
        done
        PIDS=$(echo "$PIDS" | sort -u | grep -v '^$' | tr '\n' ' ')
        KILLED=0
        for PID in $PIDS; do
            kill -9 "$PID" 2>/dev/null && KILLED=$((KILLED + 1)) || true
        done
        rm -f "$APP_PID_FILE"
        [ $KILLED -gt 0 ] && success "Terminati $KILLED processo/i" || info "Nessun processo trovato"
        success "Cleanup completato"
        return 0
    fi

    if ! app_is_running; then
        info "Application is not running"
        return 0
    fi

    local PID
    PID=$(cat "$APP_PID_FILE")
    info "Stopping application (PID: $PID)..."

    kill "$PID" 2>/dev/null || true

    local COUNT=0
    while kill -0 "$PID" 2>/dev/null && [ $COUNT -lt 10 ]; do
        sleep 1
        COUNT=$((COUNT + 1))
    done

    if kill -0 "$PID" 2>/dev/null; then
        warn "Force killing application..."
        kill -9 "$PID" 2>/dev/null || true
    fi

    rm -f "$APP_PID_FILE"
    success "Application stopped"
}

app_restart() {
    app_stop
    sleep 1
    app_start
}

app_run() {
    _app_run_common ""
}

app_debug() {
    load_env
    local DEBUG_PORT="${DEBUG_PORT:-5005}"
    info "[debug] Remote debug enabled on port $DEBUG_PORT"
    info "[debug] Attach your debugger to localhost:$DEBUG_PORT"
    _app_run_common "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:$DEBUG_PORT"
}

_app_run_common() {
    local JAVA_DEBUG_OPTS="$1"
    load_env
    cd "$WORKSPACE"

    command -v inotifywait >/dev/null 2>&1 || \
        error "inotifywait not found. Install: apt-get install -y inotify-tools"

    local DEV_LOG="$APP_LOG_FILE"
    local DEV_CP_FILE="$WORKSPACE/.dev-classpath"
    local DEV_PID=""
    local TAIL_PID=""

    _dev_classpath() {
        info "[dev] Resolving dependency classpath..."
        mvn --no-transfer-progress dependency:build-classpath -Dmdep.outputFile="$DEV_CP_FILE" \
            || error "[dev] Failed to resolve classpath"
        info "[dev] Classpath cached → .dev-classpath"
    }

    _dev_start() {
        printf '\n=== %s restart ===\n' "$(date '+%H:%M:%S')" >> "$DEV_LOG"
        local CP="$WORKSPACE/target/classes:$(cat "$DEV_CP_FILE")"
        java $JAVA_DEBUG_OPTS -cp "$CP" dev.jms.app.App >> "$DEV_LOG" 2>&1 &
        DEV_PID=$!
        echo "$DEV_PID" > "$APP_PID_FILE"
        sleep 1
        if kill -0 "$DEV_PID" 2>/dev/null; then
            success "[dev] App started (PID: $DEV_PID)"
        else
            warn "[dev] App failed to start — check $DEV_LOG"
        fi
    }

    _dev_stop() {
        if [ -n "$DEV_PID" ] && kill -0 "$DEV_PID" 2>/dev/null; then
            kill "$DEV_PID" 2>/dev/null || true
            local C=0
            while kill -0 "$DEV_PID" 2>/dev/null && [ $C -lt 10 ]; do
                sleep 0.5; C=$((C+1))
            done
            kill -9 "$DEV_PID" 2>/dev/null || true
            sleep 0.5  # attendi rilascio porta OS
        fi
        rm -f "$APP_PID_FILE"
        DEV_PID=""
    }

    _dev_cleanup() {
        _dev_stop
        [ -n "$TAIL_PID" ] && kill "$TAIL_PID" 2>/dev/null || true
        printf '\n'
        info "[dev] Dev mode stopped"
        exit 0
    }

    _dev_wait_ready() {
        local PORT="${API_PORT:-8080}"
        local MAX=30
        local i=0
        while [ $i -lt $MAX ]; do
            (echo > /dev/tcp/localhost/$PORT) 2>/dev/null && return 0
            sleep 0.5
            i=$((i+1))
        done
        warn "[dev] Backend did not become ready in time"
        return 1
    }

    trap '_dev_cleanup' INT TERM HUP

    # Kill any orphaned instance of the app (e.g. from a previous crashed session)
    pkill -f "dev.jms.app.App" 2>/dev/null || true
    rm -f "$APP_PID_FILE"

    # Classpath: resolve on first run or when pom.xml is newer
    if [ ! -f "$DEV_CP_FILE" ] || [ "$WORKSPACE/pom.xml" -nt "$DEV_CP_FILE" ]; then
        _dev_classpath
    fi

    info "[dev] Compiling..."
    mvn --no-transfer-progress compile -DskipTests || error "Initial compilation failed"

    > "$DEV_LOG"
    tail -F "$DEV_LOG" &
    TAIL_PID=$!

    info "[dev] Watching src/, config/ for changes (Ctrl+C to stop)"
    info "Internal: http://localhost:${API_PORT:-8080}/"
    info "External: http://localhost:${API_PORT_HOST:-2310}/"

    _dev_start
    _dev_wait_ready && touch "$WORKSPACE/gui/src/index.html" 2>/dev/null || true

    while true; do
        inotifywait -r -q -e modify,close_write,create,delete,moved_to \
            --exclude '.*/resources/static(/.*)?$' \
            "$WORKSPACE/src/" "$WORKSPACE/pom.xml" "$WORKSPACE/config/" 2>/dev/null || true
        sleep 0.3
        info "[dev] Change detected — recompiling..."
        if [ "$WORKSPACE/pom.xml" -nt "$DEV_CP_FILE" ]; then
            _dev_classpath
        fi
        if mvn --no-transfer-progress compile -DskipTests; then
            _dev_stop
            _dev_start
            _dev_wait_ready && touch "$WORKSPACE/gui/src/index.html" 2>/dev/null || true
        else
            warn "[dev] Compilation failed — keeping running version"
        fi
    done
}

app_status() {
    load_env

    local API_P="${API_PORT:-8080}"
    local VITE_P="${VITE_PORT:-5173}"
    local DEBUG_P="${DEBUG_PORT:-5005}"
    local ANOMALIES=0

    echo "=== Application Status ==="

    if app_is_running; then
        local PID STAT ELAPSED
        PID=$(cat "$APP_PID_FILE")
        STAT=$(ps -o stat= -p "$PID" 2>/dev/null || echo "?")
        ELAPSED=$(ps -o etime= -p "$PID" 2>/dev/null | tr -d ' ' || echo "?")
        success "RUNNING  PID=$PID  stat=$STAT  uptime=$ELAPSED"
        echo "  Internal: http://localhost:${API_P}/"
        echo "  External: http://localhost:${API_PORT_HOST:-2310}/"
    else
        warn "STOPPED"
        if [ -f "$APP_PID_FILE" ]; then
            warn "  Stale PID file: $APP_PID_FILE → usa 'cmd app stop --force'"
            ANOMALIES=$((ANOMALIES + 1))
        fi
    fi

    # Zombie java processes
    local ZOMBIES
    ZOMBIES=$(ps aux 2>/dev/null | awk '/dev\.jms\.app\.App/ && /defunct/ {printf "%s ", $2}')
    if [ -n "$ZOMBIES" ]; then
        warn "  Zombie Java: PID ${ZOMBIES}→ usa 'cmd app stop --force'"
        ANOMALIES=$((ANOMALIES + 1))
    fi

    # Port scan (internal)
    local EXPECTED_PID=""
    [ -f "$APP_PID_FILE" ] && EXPECTED_PID=$(cat "$APP_PID_FILE")

    echo ""
    echo "Ports:"
    for ENTRY in "${API_P}:API" "${VITE_P}:Vite" "${DEBUG_P}:JDWP"; do
        local P="${ENTRY%%:*}"
        local LABEL="${ENTRY##*:}"
        local OWNER
        OWNER=$(ss -tlnp "sport = :${P}" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1)
        if [ -n "$OWNER" ]; then
            local PNAME
            PNAME=$(ps -o comm= -p "$OWNER" 2>/dev/null || echo "?")
            printf "  :%s %-6s → PID %-6s (%s)\n" "$P" "($LABEL)" "$OWNER" "$PNAME"
            if [ -z "$EXPECTED_PID" ]; then
                warn "  ↳ anomalia: porta :${P} occupata ma nessun PID file → processo orfano"
                ANOMALIES=$((ANOMALIES + 1))
            elif [ "$OWNER" != "$EXPECTED_PID" ]; then
                warn "  ↳ anomalia: porta :${P} occupata da PID $OWNER, atteso PID $EXPECTED_PID"
                ANOMALIES=$((ANOMALIES + 1))
            fi
        else
            printf "  :%s %-6s → free\n" "$P" "($LABEL)"
        fi
    done

    [ $ANOMALIES -gt 0 ] && printf '\n' && warn "$ANOMALIES anomalia/e — usa 'cmd app stop --force' per il cleanup"
    return 0
}

# ============================================================================
# ngrok Operations
# ============================================================================

_ngrok_public_url() {
    curl -s http://localhost:4040/api/tunnels 2>/dev/null \
        | grep -o '"public_url":"https://[^"]*"' \
        | head -1 \
        | sed 's/"public_url":"//;s/"//'
}

_ngrok_setup() {
    load_env
    [ "${NGROK_ENABLED:-false}" = "true" ] || error "ngrok disabilitato. Abilitare in .env: NGROK_ENABLED=true"
    command -v ngrok >/dev/null 2>&1 || error "ngrok non trovato. Installare con: ./install.sh --ngrok"
    local AUTHTOKEN="${NGROK_AUTHTOKEN:-}"
    if [ -n "$AUTHTOKEN" ]; then
        ngrok config add-authtoken "$AUTHTOKEN" >/dev/null 2>&1
    fi
}

ngrok_run() {
    _ngrok_setup
    local PORT="${API_PORT:-8080}"
    info "[ngrok] Starting tunnel on port $PORT (foreground — Ctrl+C to stop)"
    info "[ngrok] Web UI: http://localhost:4040"
    printf '\n'
    exec ngrok http "$PORT" --log=stdout
}

ngrok_start() {
    _ngrok_setup
    local PORT="${API_PORT:-8080}"
    if [ -f "$NGROK_PID_FILE" ] && kill -0 "$(cat "$NGROK_PID_FILE")" 2>/dev/null; then
        warn "[ngrok] Already running (PID: $(cat "$NGROK_PID_FILE"))"
        return
    fi
    ngrok http "$PORT" --log=stdout >> /app/logs/ngrok.log 2>&1 &
    echo $! > "$NGROK_PID_FILE"
    sleep 1
    if kill -0 "$(cat "$NGROK_PID_FILE")" 2>/dev/null; then
        local url
        url=$(_ngrok_public_url)
        success "[ngrok] Started (PID: $(cat "$NGROK_PID_FILE"))"
        [ -n "$url" ] && info "[ngrok] URL: $url" || info "[ngrok] URL: not yet available (check: cmd ngrok status)"
        info "[ngrok] Web UI: http://localhost:4040"
    else
        rm -f "$NGROK_PID_FILE"
        error "[ngrok] Failed to start — check /app/logs/ngrok.log"
    fi
}

ngrok_stop() {
    local PID
    if [ -f "$NGROK_PID_FILE" ]; then
        PID=$(cat "$NGROK_PID_FILE")
        kill "$PID" 2>/dev/null || true
        rm -f "$NGROK_PID_FILE"
        info "[ngrok] Stopped (PID: $PID)"
    else
        PID=$(pgrep -f "ngrok http" | head -1)
        if [ -n "$PID" ]; then
            kill "$PID" 2>/dev/null || true
            info "[ngrok] Stopped (PID: $PID)"
        else
            info "[ngrok] Not running"
        fi
    fi
}

ngrok_status() {
    load_env
    local PID
    PID=$(pgrep -f "ngrok http" | head -1)
    if [ -n "$PID" ]; then
        local url
        url=$(_ngrok_public_url)
        success "ngrok RUNNING (PID: $PID)"
        if [ -n "$url" ]; then
            info "URL: $url"
        else
            info "URL: non ancora disponibile"
        fi
        info "Web UI: http://localhost:4040"
    else
        info "ngrok NOT RUNNING"
    fi
}

# ============================================================================
# Vite Operations
# ============================================================================

VITE_DIR="$WORKSPACE/gui"

vite_build() {
    load_env

    [ -d "$VITE_DIR" ] || error "Vite directory not found: $VITE_DIR"

    info "Building Vite application..."
    cd "$VITE_DIR"
    npm run build
    success "Vite build completed → src/main/resources/static/"
}

vite_run() {
    load_env

    [ -d "$VITE_DIR" ] || error "Vite directory not found: $VITE_DIR"

    info "Starting Vite dev server (foreground)..."
    info "URL: http://localhost:${VITE_PORT:-5173}/"
    info "API proxy: /api → http://localhost:${API_PORT:-8080}"
    info "Press Ctrl+C to stop"
    cd "$VITE_DIR"
    npm run dev -- --host 0.0.0.0
}

vite_clean() {
    load_env
    local STATIC_DIR="$WORKSPACE/src/main/resources/static"
    info "Pulizia file GUI compilati ($STATIC_DIR)..."
    rm -rf "${STATIC_DIR:?}"/*
    success "Cartella static/ svuotata"
}

# ============================================================================
# Git Operations
# ============================================================================

update_git_repo() {
    local REPO_DIR="$1"

    info "Updating repository in $REPO_DIR..."
    cd "$REPO_DIR"

    git config --global --add safe.directory "$REPO_DIR" 2>/dev/null || true
    git config user.name "$GIT_USER"
    git config user.email "$GIT_EMAIL"

    local CURRENT_REMOTE
    CURRENT_REMOTE=$(git config --get remote.origin.url 2>/dev/null || true)
    if [ -n "$CURRENT_REMOTE" ]; then
        local REPO_NAME
        REPO_NAME=$(basename -s .git "$CURRENT_REMOTE")
        git remote set-url origin "https://${GIT_USER}:${GIT_TOKEN}@github.com/${GIT_USER}/${REPO_NAME}.git"
    fi

    info "  Staging changes..."
    git add . || { warn "Failed to stage changes"; cd "$WORKSPACE"; return 1; }

    info "  Creating commit..."
    if git commit -m "updated"; then
        info "  Changes committed"
    else
        info "  No changes to commit"
    fi

    cd "$WORKSPACE"
}

push_only_git_repo() {
    local REPO_DIR="$1"

    info "Pushing to remote from $REPO_DIR..."
    cd "$REPO_DIR"

    git config --global --add safe.directory "$REPO_DIR" 2>/dev/null || true

    local CURRENT_REMOTE
    CURRENT_REMOTE=$(git config --get remote.origin.url 2>/dev/null || true)
    if [ -n "$CURRENT_REMOTE" ]; then
        local REPO_NAME
        REPO_NAME=$(basename -s .git "$CURRENT_REMOTE")
        git remote set-url origin "https://${GIT_USER}:${GIT_TOKEN}@github.com/${GIT_USER}/${REPO_NAME}.git"
    fi

    if git push; then
        success "Successfully pushed"
    else
        warn "Failed to push changes. Check credentials and network."
        cd "$WORKSPACE"
        return 1
    fi

    cd "$WORKSPACE"
}

pull_git_repo() {
    local REPO_DIR="$1"

    info "Pulling repository in $REPO_DIR..."
    cd "$REPO_DIR"

    git config --global --add safe.directory "$REPO_DIR" 2>/dev/null || true
    git config user.name "$GIT_USER"
    git config user.email "$GIT_EMAIL"

    info "  Pulling from remote..."
    if git pull; then
        success "Successfully pulled"
    else
        warn "Failed to pull changes. Check credentials and network."
        cd "$WORKSPACE"
        return 1
    fi

    cd "$WORKSPACE"
}

_resolve_repo_dir() {
    local REPO_PATH="$1"
    if [ -z "$REPO_PATH" ]; then
        echo "$WORKSPACE"
    elif [ "${REPO_PATH#/}" != "$REPO_PATH" ]; then
        echo "$REPO_PATH"
    else
        echo "$WORKSPACE/$REPO_PATH"
    fi
}

_require_git_env() {
    [ -n "$GIT_USER" ]  || error "GIT_USER not set in .env file"
    [ -n "$GIT_EMAIL" ] || error "GIT_EMAIL not set in .env file"
    [ -n "$GIT_TOKEN" ] || error "GIT_TOKEN not set in .env file"
}

_get_repo_name() {
    local REPO_DIR="$1"
    local NAME
    NAME=$(basename -s .git "$(git -C "$REPO_DIR" config --get remote.origin.url 2>/dev/null)")
    [ -n "$NAME" ] || error "Cannot determine repository name. No remote.origin.url found in $REPO_DIR"
    echo "$NAME"
}

git_push() {
    local REPO_PATH="$1"
    load_env
    local GIT_REPO_DIR
    GIT_REPO_DIR=$(_resolve_repo_dir "$REPO_PATH")
    [ -d "$GIT_REPO_DIR/.git" ] || error "$GIT_REPO_DIR is not a git repository"
    git config --global --add safe.directory "$GIT_REPO_DIR" 2>/dev/null || true
    local REPO_NAME
    REPO_NAME=$(_get_repo_name "$GIT_REPO_DIR")
    _require_git_env
    confirm "Push changes to remote ($REPO_NAME at $GIT_REPO_DIR)?" || exit 0
    update_git_repo "$GIT_REPO_DIR"
    push_only_git_repo "$GIT_REPO_DIR"
}

git_pull() {
    local REPO_PATH="$1"
    load_env
    local GIT_REPO_DIR
    GIT_REPO_DIR=$(_resolve_repo_dir "$REPO_PATH")
    [ -d "$GIT_REPO_DIR/.git" ] || error "$GIT_REPO_DIR is not a git repository"
    git config --global --add safe.directory "$GIT_REPO_DIR" 2>/dev/null || true
    local REPO_NAME
    REPO_NAME=$(_get_repo_name "$GIT_REPO_DIR")
    _require_git_env
    confirm "Pull changes from remote ($REPO_NAME at $GIT_REPO_DIR)?" || exit 0
    pull_git_repo "$GIT_REPO_DIR"
}

git_sync() {
    local REPO_PATH="$1"
    load_env
    local GIT_REPO_DIR
    GIT_REPO_DIR=$(_resolve_repo_dir "$REPO_PATH")
    [ -d "$GIT_REPO_DIR/.git" ] || error "$GIT_REPO_DIR is not a git repository"
    git config --global --add safe.directory "$GIT_REPO_DIR" 2>/dev/null || true
    local REPO_NAME
    REPO_NAME=$(_get_repo_name "$GIT_REPO_DIR")
    _require_git_env
    confirm "Sync repository ($REPO_NAME at $GIT_REPO_DIR)?" || exit 0
    pull_git_repo "$GIT_REPO_DIR"
    update_git_repo "$GIT_REPO_DIR"
    push_only_git_repo "$GIT_REPO_DIR"
}

git_fetch() {
    load_env
    [ ! -d "$WORKSPACE/.git" ] || error "Git repository already exists. Remove .git folder first if you want to reinitialize."
    [ -n "$PROJECT_NAME" ] || error "PROJECT_NAME not set in .env file"
    _require_git_env

    warn "I file locali verranno sovrascritti con i contenuti del repository remoto."
    confirm "Inizializzare il repository da remoto ($PROJECT_NAME)?" || exit 0

    local GIT_URL="https://${GIT_USER}:${GIT_TOKEN}@github.com/${GIT_USER}/${PROJECT_NAME}.git"
    info "Initializing repository from remote..."
    info "  Project: $PROJECT_NAME"
    info "  User: $GIT_USER"
    cd "$WORKSPACE"
    git init || error "Failed to initialize git repository"
    git remote add origin "$GIT_URL" || error "Failed to add remote origin"
    git fetch origin || error "Failed to fetch from origin"
    git reset --hard origin/main || error "Failed to reset to origin/main"
    git branch -m master main 2>/dev/null || true
    git branch -u origin/main || error "Failed to set upstream"
    success "Repository initialized from remote"
}

auto_stash_save() {
    local CURRENT_BRANCH="$1"
    if ! git diff-index --quiet HEAD -- 2>/dev/null; then
        info "  Saving uncommitted changes to stash..."
        git stash push -u -m "autostash-${CURRENT_BRANCH}" >/dev/null 2>&1 || { warn "Failed to stash changes"; return 1; }
        success "  Uncommitted changes stashed"
        return 0
    fi
    return 1
}

auto_stash_pop() {
    local TARGET_BRANCH="$1"
    local STASH_NAME="autostash-${TARGET_BRANCH}"
    if git stash list | grep -q "$STASH_NAME"; then
        local STASH_INDEX
        STASH_INDEX=$(git stash list | grep -n "$STASH_NAME" | head -1 | cut -d: -f1)
        STASH_INDEX=$((STASH_INDEX - 1))
        info "  Restoring stash '$STASH_NAME'..."
        git stash pop "stash@{$STASH_INDEX}" >/dev/null 2>&1 && success "  Uncommitted changes restored" || warn "Failed to restore stash"
    fi
}

git_branch() {
    local BRANCH_NAME="$1"
    local REPO_PATH="$2"
    local BASE_BRANCH="${3:-main}"
    load_env
    local GIT_REPO_DIR
    GIT_REPO_DIR=$(_resolve_repo_dir "$REPO_PATH")
    [ -d "$GIT_REPO_DIR/.git" ] || error "$GIT_REPO_DIR is not a git repository"

    if [ -z "$BRANCH_NAME" ]; then
        git -C "$GIT_REPO_DIR" branch --show-current
        return 0
    fi

    git config --global --add safe.directory "$GIT_REPO_DIR" 2>/dev/null || true
    local REPO_NAME
    REPO_NAME=$(_get_repo_name "$GIT_REPO_DIR")
    _require_git_env

    cd "$GIT_REPO_DIR"
    git config user.name "$GIT_USER"
    git config user.email "$GIT_EMAIL"

    local CURRENT_BRANCH
    CURRENT_BRANCH=$(git branch --show-current)
    local STASHED=false
    auto_stash_save "$CURRENT_BRANCH" && STASHED=true

    if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
        info "  Branch '$BRANCH_NAME' exists locally, switching..."
        git switch "$BRANCH_NAME" || error "Failed to switch to branch"
        auto_stash_pop "$BRANCH_NAME"
        if ! git ls-remote --exit-code --heads origin "$BRANCH_NAME" >/dev/null 2>&1; then
            git push -u origin "$BRANCH_NAME" && success "Branch '$BRANCH_NAME' pushed to remote" || warn "Failed to push branch to remote"
        fi
        cd "$WORKSPACE"
        success "Switched to branch '$BRANCH_NAME' in $REPO_NAME"
        return 0
    fi

    if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH"; then
        git ls-remote --exit-code --heads origin "$BASE_BRANCH" >/dev/null 2>&1 || error "Base branch '$BASE_BRANCH' does not exist"
        git fetch origin "$BASE_BRANCH:$BASE_BRANCH" || error "Failed to fetch base branch"
    fi

    git switch "$BASE_BRANCH" || error "Failed to switch to base branch"
    git pull origin "$BASE_BRANCH" || warn "Failed to pull from remote. Using local state."
    git switch -c "$BRANCH_NAME" || error "Failed to create branch '$BRANCH_NAME'"
    [ "$STASHED" = true ] && auto_stash_pop "$CURRENT_BRANCH"
    git push -u origin "$BRANCH_NAME" && success "Branch '$BRANCH_NAME' created and pushed" || warn "Branch created locally but failed to push"
    cd "$WORKSPACE"
}

git_merge() {
    local BRANCH_NAME="$1"
    local REPO_PATH="$2"
    load_env
    [ -n "$BRANCH_NAME" ] || error "Branch name is required. Use: cmd git merge -b <branch-name>"
    if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then error "Cannot merge main/master into itself"; fi

    local GIT_REPO_DIR
    GIT_REPO_DIR=$(_resolve_repo_dir "$REPO_PATH")
    [ -d "$GIT_REPO_DIR/.git" ] || error "$GIT_REPO_DIR is not a git repository"
    git config --global --add safe.directory "$GIT_REPO_DIR" 2>/dev/null || true
    local REPO_NAME
    REPO_NAME=$(_get_repo_name "$GIT_REPO_DIR")
    _require_git_env
    confirm "Merge '$BRANCH_NAME' into main and delete it ($REPO_NAME)?" || exit 0

    cd "$GIT_REPO_DIR"
    git config user.name "$GIT_USER"
    git config user.email "$GIT_EMAIL"

    local MAIN_BRANCH="main"
    git show-ref --verify --quiet "refs/heads/master" && ! git show-ref --verify --quiet "refs/heads/main" && MAIN_BRANCH="master"

    git show-ref --verify --quiet "refs/heads/$BRANCH_NAME" || error "Branch '$BRANCH_NAME' does not exist locally"
    git switch "$MAIN_BRANCH" || error "Failed to switch to $MAIN_BRANCH"
    git merge "$BRANCH_NAME" --no-edit || error "Merge failed. Resolve conflicts manually."
    git branch -d "$BRANCH_NAME" && info "  Local branch deleted" || warn "Failed to delete local branch"
    if git ls-remote --exit-code --heads origin "$BRANCH_NAME" >/dev/null 2>&1; then
        git push origin --delete "$BRANCH_NAME" && success "Remote branch '$BRANCH_NAME' deleted" || warn "Failed to delete remote branch"
    fi
    cd "$WORKSPACE"
    info "Note: Use 'cmd git push' to push merged changes to remote"
}

git_init() {
    load_env
    [ -n "$PROJECT_NAME" ] || error "PROJECT_NAME non impostato nel file .env"
    _require_git_env

    [ ! -d "$WORKSPACE/.git" ] || error "Repository git già esistente in $WORKSPACE. Usare 'cmd git fetch' per clonare da remoto su un progetto esistente."

    local GIT_URL="https://${GIT_USER}:${GIT_TOKEN}@github.com/${GIT_USER}/${PROJECT_NAME}.git"

    info "[git init] Repository: https://github.com/${GIT_USER}/${PROJECT_NAME}.git"
    info "[git init] User:       $GIT_USER <$GIT_EMAIL>"
    printf '\n'
    confirm "Inizializzare e pubblicare il progetto '$PROJECT_NAME' su GitHub?" || exit 0

    cd "$WORKSPACE"

    git config --global --add safe.directory "$WORKSPACE" 2>/dev/null || true
    git init || error "git init fallito"
    git config user.name "$GIT_USER"
    git config user.email "$GIT_EMAIL"

    info "  Staging di tutti i file..."
    git add .

    info "  Creazione del primo commit..."
    git commit -m "first commit" || error "git commit fallito"

    git branch -M main

    info "  Aggiunta remote origin..."
    git remote add origin "$GIT_URL" || error "git remote add fallito"

    info "  Push su origin/main..."
    git push -u origin main || error "git push fallito — verificare che il repository esista su GitHub e che il token abbia i permessi necessari"

    printf '\n'
    success "Repository pubblicato: https://github.com/${GIT_USER}/${PROJECT_NAME}"
    printf '\n'
}

git_update() {
    local REPO_PATH="$1"
    load_env
    [ -n "$GIT_USER" ]  || error "GIT_USER not set in .env file"
    [ -n "$GIT_TOKEN" ] || error "GIT_TOKEN not set in .env file"

    local GIT_REPO_DIR
    GIT_REPO_DIR=$(_resolve_repo_dir "$REPO_PATH")
    git config --global --add safe.directory "$GIT_REPO_DIR" 2>/dev/null || true
    git config --global user.name "$GIT_USER"
    [ -n "$GIT_EMAIL" ] && git config --global user.email "$GIT_EMAIL"

    if [ -d "$GIT_REPO_DIR/.git" ]; then
        local CURRENT_REMOTE REPO_NAME NEW_URL
        CURRENT_REMOTE=$(git -C "$GIT_REPO_DIR" config --get remote.origin.url 2>/dev/null || echo "")
        if [ -n "$CURRENT_REMOTE" ]; then
            REPO_NAME=$(basename -s .git "$CURRENT_REMOTE")
            NEW_URL="https://${GIT_USER}:${GIT_TOKEN}@github.com/${GIT_USER}/${REPO_NAME}.git"
            git -C "$GIT_REPO_DIR" remote set-url origin "$NEW_URL"
            success "Remote URL updated for $REPO_NAME"
        else
            warn "No remote origin found"
        fi
    else
        warn "Not a git repository, skipping remote URL update"
    fi

    success "Git configuration updated (user: $GIT_USER)"
}

# ============================================================================
# Database Operations (PostgreSQL)
# ============================================================================

db_cli() {
    load_env
    local FILE="$1"

    [ "$PGSQL_ENABLED" = "true" ] || error "PostgreSQL is not enabled. Set PGSQL_ENABLED=true in .env"

    export PGPASSWORD="$PGSQL_ROOT_PASSWORD"
    local PG_HOST="${PGSQL_HOST:-postgres}"
    local PG_PORT="${PGSQL_PORT:-5432}"

    if [ -n "$FILE" ]; then
        [ -f "$FILE" ] || error "File not found: $FILE"
        local FILE_EXT="${FILE##*.}"

        if [ "$FILE_EXT" = "csv" ]; then
            local TABLE_NAME
            TABLE_NAME=$(basename "$FILE" .csv)
            info "Loading CSV into table: $TABLE_NAME"
            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" \
                -c "\\COPY $TABLE_NAME FROM '$FILE' WITH (FORMAT CSV, HEADER true, DELIMITER ';')"
            success "CSV file loaded"
        elif [ "$FILE_EXT" = "sql" ]; then
            info "Executing SQL file: $FILE"
            psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" -f "$FILE"
            success "SQL file executed"
        else
            error "Unsupported file type. Use .sql or .csv"
        fi
    else
        info "Connecting to PostgreSQL ($PGSQL_NAME)..."
        psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME"
    fi
}

db_cli_query() {
    load_env
    local SQL="$1"

    [ "$PGSQL_ENABLED" = "true" ] || error "PostgreSQL is not enabled. Set PGSQL_ENABLED=true in .env"

    export PGPASSWORD="$PGSQL_ROOT_PASSWORD"
    local PG_HOST="${PGSQL_HOST:-postgres}"
    local PG_PORT="${PGSQL_PORT:-5432}"

    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" -c "$SQL"
}

db_reset() {
    load_env
    [ "$PGSQL_ENABLED" = "true" ] || error "PostgreSQL is not enabled. Set PGSQL_ENABLED=true in .env"

    warn "This will DELETE all data in $PGSQL_NAME and recreate it!"
    confirm "Are you sure you want to reset the database?" || exit 0

    export PGPASSWORD="$PGSQL_ROOT_PASSWORD"
    local PG_HOST="${PGSQL_HOST:-postgres}"
    local PG_PORT="${PGSQL_PORT:-5432}"

    info "Dropping database $PGSQL_NAME..."
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
        -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$PGSQL_NAME' AND pid <> pg_backend_pid();" 2>/dev/null || true
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
        -c "DROP DATABASE IF EXISTS $PGSQL_NAME;" 2>/dev/null || true

    info "Creating database $PGSQL_NAME..."
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
        -c "CREATE DATABASE $PGSQL_NAME;" || error "Failed to create database"

    info "Granting privileges to $PGSQL_USER..."
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" \
        -c "GRANT ALL ON SCHEMA public TO \"$PGSQL_USER\";" 2>/dev/null || true

    success "Database reset completed"
}

db_setup() {
    load_env
    [ "$PGSQL_ENABLED" = "true" ] || error "PostgreSQL is not enabled. Set PGSQL_ENABLED=true in .env"

    export PGPASSWORD="$PGSQL_ROOT_PASSWORD"
    local PG_HOST="${PGSQL_HOST:-postgres}"
    local PG_PORT="${PGSQL_PORT:-5432}"

    info "Creating role $PGSQL_USER..."
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
        -c "DO \$\$ BEGIN IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '$PGSQL_USER') THEN CREATE ROLE \"$PGSQL_USER\" WITH LOGIN PASSWORD '$PGSQL_PASSWORD'; END IF; END \$\$;"

    info "Creating database $PGSQL_NAME..."
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
        -c "SELECT 1 FROM pg_database WHERE datname = '$PGSQL_NAME'" | grep -q 1 || \
    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d postgres \
        -c "CREATE DATABASE \"$PGSQL_NAME\" OWNER \"$PGSQL_USER\";"

    psql -h "$PG_HOST" -p "$PG_PORT" -U "$PGSQL_ROOT_USER" -d "$PGSQL_NAME" \
        -c "GRANT ALL ON SCHEMA public TO \"$PGSQL_USER\";"

    success "Database $PGSQL_NAME configured for user $PGSQL_USER"
}

db_status() {
    local CONFIG_FILE="/app/config/application.properties"

    _prop() {
        grep "^${1}=" "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '\r'
    }

    local DB_HOST DB_PORT DB_NAME DB_USER DB_PASS DB_POOL
    local SRC_HOST="default" SRC_PORT="default" SRC_NAME="default"
    local SRC_USER="default" SRC_PASS="default" SRC_POOL="default"

    DB_HOST="localhost"; DB_PORT="5432"; DB_NAME="app"
    DB_USER="app";       DB_PASS="";     DB_POOL="10"

    if [ -f "$CONFIG_FILE" ]; then
        local VAL
        VAL=$(_prop "db.host");      [ -n "$VAL" ] && { DB_HOST="$VAL"; SRC_HOST="file"; }
        VAL=$(_prop "db.port");      [ -n "$VAL" ] && { DB_PORT="$VAL"; SRC_PORT="file"; }
        VAL=$(_prop "db.name");      [ -n "$VAL" ] && { DB_NAME="$VAL"; SRC_NAME="file"; }
        VAL=$(_prop "db.user");      [ -n "$VAL" ] && { DB_USER="$VAL"; SRC_USER="file"; }
        VAL=$(_prop "db.password");  [ -n "$VAL" ] && { DB_PASS="$VAL"; SRC_PASS="file"; }
        VAL=$(_prop "db.pool.size"); [ -n "$VAL" ] && { DB_POOL="$VAL"; SRC_POOL="file"; }
    fi

    # Env var overrides (Config.java: db.host → DB_HOST, db.pool.size → DB_POOL_SIZE)
    local ENV_VAL
    ENV_VAL=$(printenv DB_HOST 2>/dev/null || true);      [ -n "$ENV_VAL" ] && { DB_HOST="$ENV_VAL"; SRC_HOST="env"; }
    ENV_VAL=$(printenv DB_PORT 2>/dev/null || true);      [ -n "$ENV_VAL" ] && { DB_PORT="$ENV_VAL"; SRC_PORT="env"; }
    ENV_VAL=$(printenv DB_NAME 2>/dev/null || true);      [ -n "$ENV_VAL" ] && { DB_NAME="$ENV_VAL"; SRC_NAME="env"; }
    ENV_VAL=$(printenv DB_USER 2>/dev/null || true);      [ -n "$ENV_VAL" ] && { DB_USER="$ENV_VAL"; SRC_USER="env"; }
    ENV_VAL=$(printenv DB_PASSWORD 2>/dev/null || true);  [ -n "$ENV_VAL" ] && { DB_PASS="$ENV_VAL"; SRC_PASS="env"; }
    ENV_VAL=$(printenv DB_POOL_SIZE 2>/dev/null || true); [ -n "$ENV_VAL" ] && { DB_POOL="$ENV_VAL"; SRC_POOL="env"; }

    echo "=== Database Status ==="
    if [ -f "$CONFIG_FILE" ]; then
        echo "Config: $CONFIG_FILE"
    else
        warn "Config file not found: $CONFIG_FILE (using defaults)"
    fi
    echo ""
    printf "  %-12s %-24s (%s)\n" "host:"      "$DB_HOST"  "$SRC_HOST"
    printf "  %-12s %-24s (%s)\n" "port:"      "$DB_PORT"  "$SRC_PORT"
    printf "  %-12s %-24s (%s)\n" "database:"  "$DB_NAME"  "$SRC_NAME"
    printf "  %-12s %-24s (%s)\n" "user:"      "$DB_USER"  "$SRC_USER"
    printf "  %-12s %-24s (%s)\n" "password:"  "***"       "$SRC_PASS"
    printf "  %-12s %-24s (%s)\n" "pool.size:" "$DB_POOL"  "$SRC_POOL"
    echo ""

    export PGPASSWORD="$DB_PASS"
    local CONN_OUT
    CONN_OUT=$(psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" \
        -c "SHOW server_version;" -t 2>&1)

    if echo "$CONN_OUT" | grep -qE "^[[:space:]]*[0-9]+"; then
        success "Connection: OK"
        printf "  Server: PostgreSQL %s\n" "$(echo "$CONN_OUT" | tr -d ' ')"
        echo ""
        echo "=== Migrations ==="
        local MIGRATIONS
        MIGRATIONS=$(psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" -t \
            -c "SELECT '  ' || lpad(installed_rank::text,3) || '  ' || rpad(version,24) || '  ' || rpad(description,28) || '  ' || to_char(installed_on,'YYYY-MM-DD HH24:MI') || '  ' || CASE WHEN success THEN 'OK' ELSE 'FAILED' END FROM flyway_schema_history ORDER BY installed_rank;" \
            2>/dev/null || true)
        if [ -n "$MIGRATIONS" ]; then
            printf "  %-3s  %-24s  %-28s  %-16s  %s\n" "#" "version" "description" "installed_on" "status"
            echo "$MIGRATIONS"
        else
            echo "  (no migrations found — flyway_schema_history may not exist yet)"
        fi
    else
        warn "Connection: FAILED"
        echo "  $CONN_OUT"
    fi
}

# ============================================================================
# Module Operations (export / import)
# ============================================================================


# ============================================================================
# _module_paths — deriva i path di installazione dal MODULE_KEY
#
# Argomento: MODULE_KEY (es. "user" oppure "cti/vonage")
#
# Tutti i moduli installati (top-level e con namespace) usano app/module/:
#
# Moduli top-level (nessun namespace, es. "user"):
#   Java  → src/main/java/dev/jms/app/module/<name>/
#   GUI   → gui/src/module/<name>/
#   pkg   → dev.jms.app.module.<name>
#
# Moduli con namespace (es. "cti/vonage"):
#   Java  → src/main/java/dev/jms/app/module/<ns>/<name>/
#   GUI   → gui/src/module/<ns>/<name>/
#   pkg   → dev.jms.app.module.<ns_dotted>.<name>
#
# Imposta le variabili: MODULE_NAME, MODULE_NS,
#   JAVA_DIR, GUI_DIR, JAVA_PKG, GUI_PATH, TRACKER_DIR
# ============================================================================

_module_paths() {
    local KEY="${1%/}"

    if echo "$KEY" | grep -q '/'; then
        MODULE_NAME="${KEY##*/}"
        MODULE_NS="${KEY%/*}"
        local NS_DOTTED="${MODULE_NS//\//.}"
        JAVA_DIR="$WORKSPACE/src/main/java/dev/jms/app/module/$MODULE_NS/$MODULE_NAME"
        GUI_DIR="$WORKSPACE/gui/src/module/$MODULE_NS/$MODULE_NAME"
        JAVA_PKG="dev.jms.app.module.${NS_DOTTED}.${MODULE_NAME}"
        GUI_PATH="$KEY"
    else
        MODULE_NAME="$KEY"
        MODULE_NS=""
        JAVA_DIR="$WORKSPACE/src/main/java/dev/jms/app/module/$MODULE_NAME"
        GUI_DIR="$WORKSPACE/gui/src/module/$MODULE_NAME"
        JAVA_PKG="dev.jms.app.module.$MODULE_NAME"
        GUI_PATH="$MODULE_NAME"
    fi
    TRACKER_DIR="$WORKSPACE/src/main/resources/module/$KEY"
}

# ============================================================================
# _rewrite_java_packages — aggiorna package e import nei .java copiati
#
# Legge il package corrente da Routes.java nella cartella indicata;
# se diverso dal target, aggiorna tutti i .java (package + import).
# ============================================================================

_rewrite_java_packages() {
    local JAVA_INSTALL_DIR="$1"
    local NEW_PKG="$2"

    local ROUTES_FILE="$JAVA_INSTALL_DIR/Routes.java"
    [ -f "$ROUTES_FILE" ] || return 0

    local OLD_PKG
    OLD_PKG=$(python3 -c "
import re, sys
with open('$ROUTES_FILE') as f:
    for line in f:
        m = re.match(r'^package (dev\.jms\.app\.\S+?);', line.strip())
        if m:
            print(m.group(1))
            sys.exit(0)
" 2>/dev/null || true)

    [ -z "$OLD_PKG" ] && return 0
    [ "$OLD_PKG" = "$NEW_PKG" ] && return 0

    python3 -c "
import os, re
java_dir = '$JAVA_INSTALL_DIR'
old_pkg  = '$OLD_PKG'
new_pkg  = '$NEW_PKG'
for root, dirs, files in os.walk(java_dir):
    for name in files:
        if not name.endswith('.java'):
            continue
        path = os.path.join(root, name)
        with open(path) as f:
            content = f.read()
        content = re.sub(
            r'^package ' + re.escape(old_pkg) + r'((?:\.\w+)*);',
            lambda m: 'package ' + new_pkg + m.group(1) + ';',
            content, count=1, flags=re.MULTILINE)
        content = content.replace('import ' + old_pkg + '.', 'import ' + new_pkg + '.')
        with open(path, 'w') as f:
            f.write(content)
" 2>/dev/null
}

# ============================================================================
# _module_install — installa un modulo dalla sua cartella sorgente
#
# Argomenti: MODULE_DIR  (path assoluto della cartella modulo)
#            MODULE_KEY  (path relativo a module/, es. "user" o "cti/vonage")
# ============================================================================

# ============================================================================
# _module_manifest_update — rigenera src/main/resources/module/installed.json
# con la mappa key→{name,version,dependencies} di tutti i moduli installati.
# Chiamato automaticamente da _module_install e module_remove.
# ============================================================================

_module_manifest_update() {
    local TRACKER_BASE="$WORKSPACE/src/main/resources/module"
    local MANIFEST="$TRACKER_BASE/installed.json"
    python3 -c "
import json, os

tracker_base = '$TRACKER_BASE'
installed = {}

for root, dirs, files in os.walk(tracker_base):
    for f in files:
        if f != 'module.json':
            continue
        path = os.path.join(root, f)
        try:
            m = json.load(open(path))
            name = m.get('name', '')
            key = os.path.relpath(os.path.dirname(path), tracker_base)
            if name:
                installed[key] = {
                    'name': name,
                    'version': m.get('version', ''),
                    'dependencies': m.get('dependencies', {})
                }
        except Exception:
            pass

with open('$MANIFEST', 'w') as f:
    json.dump(installed, f, indent=2)
    f.write('\n')
" 2>/dev/null || true
}

_module_install() {
    local MODULE_DIR="$1"
    local MODULE_KEY="$2"
    [ -d "$MODULE_DIR" ]        || error "Cartella modulo non trovata: $MODULE_DIR"
    [ -f "$MODULE_DIR/module.json" ] || error "module.json non trovato in: $MODULE_DIR"
    [ -n "$MODULE_KEY" ]        || error "MODULE_KEY mancante (bug interno)"

    local MODULE
    MODULE=$(python3 -c "import json; print(json.load(open('$MODULE_DIR/module.json'))['name'])" 2>/dev/null)
    [ -n "$MODULE" ] || error "Impossibile leggere 'name' da $MODULE_DIR/module.json"

    local MODULE_NAME MODULE_NS JAVA_DIR GUI_DIR JAVA_PKG GUI_PATH TRACKER_DIR
    _module_paths "$MODULE_KEY"

    printf '\n'
    info "[module] Installazione modulo: $MODULE (key: $MODULE_KEY)"
    printf '\n'

    # Java sources
    if [ -d "$MODULE_DIR/api" ]; then
        info "[module] Copia file Java..."
        mkdir -p "$JAVA_DIR"
        cp -r "$MODULE_DIR/api/." "$JAVA_DIR/"
        _rewrite_java_packages "$JAVA_DIR" "$JAVA_PKG"
        success "  File Java installati: ${JAVA_DIR#$WORKSPACE/}"
    fi

    # GUI sources
    if [ -d "$MODULE_DIR/gui" ]; then
        info "[module] Copia file GUI..."
        mkdir -p "$GUI_DIR"
        cp -r "$MODULE_DIR/gui/." "$GUI_DIR/"
        success "  File GUI installati: ${GUI_DIR#$WORKSPACE/}"
    fi

    # Migration SQL (copy as-is, no timestamp rename)
    if [ -d "$MODULE_DIR/migration" ] && ls "$MODULE_DIR/migration"/*.sql >/dev/null 2>&1; then
        info "[module] Copia migration SQL..."
        for sql_file in "$MODULE_DIR/migration"/*.sql; do
            cp "$sql_file" "$WORKSPACE/src/main/resources/db/migration/"
            success "  Migration copiata: $(basename "$sql_file")"
        done
    fi

    # Auto-insert route registration into App.java (after // [MODULE_ROUTES] marker)
    local APP_JAVA="$WORKSPACE/src/main/java/dev/jms/app/App.java"
    if [ -f "$APP_JAVA" ]; then
        local REGISTER_CALL=""
        local ROUTES_FILE="$JAVA_DIR/Routes.java"
        if [ -f "$ROUTES_FILE" ]; then
            REGISTER_CALL="${JAVA_PKG}.Routes.register(router);"
            if grep -q 'Config config' "$ROUTES_FILE" 2>/dev/null; then
                REGISTER_CALL="${JAVA_PKG}.Routes.register(router, config);"
            fi
        fi
        if [ -n "$REGISTER_CALL" ]; then
            if grep -q '\[MODULE_ROUTES\]' "$APP_JAVA"; then
                if ! grep -qF "$REGISTER_CALL" "$APP_JAVA"; then
                    sed -i "s|// \[MODULE_ROUTES\]|// [MODULE_ROUTES]\n    ${REGISTER_CALL}|" "$APP_JAVA"
                    success "  Route registrata in App.java: $REGISTER_CALL"
                else
                    warn "  Route già registrata in App.java, skip"
                fi
            else
                warn "  Marker [MODULE_ROUTES] non trovato in App.java — aggiungi manualmente: $REGISTER_CALL"
            fi
        fi
    fi

    # Auto-insert config.js entry (after // [MODULE_ENTRIES] marker)
    # GUI_PATH è già corretto (es. "cti/vonage" per moduli con namespace)
    local CONFIG_JS="$WORKSPACE/gui/src/config.js"
    if [ -f "$CONFIG_JS" ]; then
        local CONFIG_ENTRY_KEY
        CONFIG_ENTRY_KEY=$(python3 -c "
import json
with open('$MODULE_DIR/module.json') as f:
    m = json.load(f)
print(m.get('name', ''))
" 2>/dev/null || true)
        local CONFIG_ENTRY_JS
        CONFIG_ENTRY_JS=$(python3 -c "
import json, sys
with open('$MODULE_DIR/module.json') as f:
    m = json.load(f)
cfg = m.get('gui', {}).get('config')
if not cfg:
    sys.exit(0)
cfg = dict(cfg)
cfg['path'] = '$GUI_PATH'
name = m.get('name', '')
lines = ['  ' + name + ': {']
for k, v in cfg.items():
    if v is None:
        lines.append('    ' + k + ': null,')
    elif isinstance(v, bool):
        lines.append('    ' + k + ': ' + ('true' if v else 'false') + ',')
    elif isinstance(v, int):
        lines.append('    ' + k + ': ' + str(v) + ',')
    elif isinstance(v, dict):
        inner = ', '.join(json.dumps(ik) + ': ' + json.dumps(iv) for ik, iv in v.items())
        lines.append('    ' + k + ': { ' + inner + ' },')
    elif isinstance(v, str) and v.startswith('__LAMBDA__:'):
        lines.append('    ' + k + ': ' + v[len('__LAMBDA__:'):] + ',')
    else:
        lines.append('    ' + k + ': ' + json.dumps(str(v)) + ',')
lines.append('  },')
print('\n'.join(lines))
" 2>/dev/null || true)
        if [ -n "$CONFIG_ENTRY_JS" ] && [ -n "$CONFIG_ENTRY_KEY" ]; then
            if grep -q '\[MODULE_ENTRIES\]' "$CONFIG_JS"; then
                if ! grep -qE "^\s+${CONFIG_ENTRY_KEY}:" "$CONFIG_JS"; then
                    python3 -c "
import sys
with open('$CONFIG_JS') as f:
    content = f.read()
marker = '  // [MODULE_ENTRIES]'
entry = '''$CONFIG_ENTRY_JS'''
replacement = marker + '\n' + entry
content = content.replace(marker, replacement, 1)
with open('$CONFIG_JS', 'w') as f:
    f.write(content)
" 2>/dev/null && success "  Modulo aggiunto a config.js: $CONFIG_ENTRY_KEY" \
                       || warn "  Impossibile aggiornare config.js — aggiungi manualmente il modulo '$CONFIG_ENTRY_KEY'"
                else
                    warn "  Modulo '$CONFIG_ENTRY_KEY' già presente in config.js, skip"
                fi
            else
                warn "  Marker [MODULE_ENTRIES] non trovato in config.js — aggiungi manualmente il modulo '$CONFIG_ENTRY_KEY'"
            fi
        fi
    fi

    # Append module config/application.properties to project config (idempotent via markers)
    if [ -f "$MODULE_DIR/config/application.properties" ]; then
        local APP_PROPS="$WORKSPACE/config/application.properties"
        local PROP_MARKER="${MODULE_KEY//\//-}"
        if grep -qF "# [MODULE:${PROP_MARKER}]" "$APP_PROPS" 2>/dev/null; then
            info "[module] Proprietà già presenti in config/application.properties, skip"
        else
            info "[module] Aggiorno config/application.properties..."
            printf '\n# [MODULE:%s]\n' "$PROP_MARKER" >> "$APP_PROPS"
            cat "$MODULE_DIR/config/application.properties" >> "$APP_PROPS"
            printf '# [/MODULE:%s]\n' "$PROP_MARKER" >> "$APP_PROPS"
            success "  Proprietà aggiunte a config/application.properties"
        fi
    fi

    # Append module config/.env to project .env (idempotent via markers)
    if [ -f "$MODULE_DIR/config/.env" ]; then
        local ENV_FILE="$WORKSPACE/.env"
        local ENV_MARKER="${MODULE_KEY//\//-}"
        if grep -qF "# [MODULE:${ENV_MARKER}]" "$ENV_FILE" 2>/dev/null; then
            info "[module] Variabili .env già presenti, skip"
        else
            info "[module] Aggiorno .env..."
            printf '\n# [MODULE:%s]\n' "$ENV_MARKER" >> "$ENV_FILE"
            cat "$MODULE_DIR/config/.env" >> "$ENV_FILE"
            printf '# [/MODULE:%s]\n' "$ENV_MARKER" >> "$ENV_FILE"
            success "  Variabili aggiunte a .env"
        fi
    fi

    # Maven profile installation
    if [ -f "$MODULE_DIR/profile.xml" ]; then
        info "[module] Aggiungo Maven profile al pom.xml..."

        local POM="$WORKSPACE/pom.xml"
        local PROFILE_MARKER="${MODULE_KEY//\//-}"
        local PROFILE_XML
        PROFILE_XML=$(cat "$MODULE_DIR/profile.xml")

        awk -v profile="$PROFILE_XML" -v marker="$PROFILE_MARKER" '
            /<!-- \[MODULE_PROFILES\] -->/ {
                print
                print "<!-- [MODULE:" marker "] -->"
                print profile
                print "<!-- [/MODULE:" marker "] -->"
                next
            }
            {print}
        ' "$POM" > "$POM.tmp" && mv "$POM.tmp" "$POM"

        success "  Maven profile aggiunto al pom.xml"
    else
        warn "  Nessun Maven profile (profile.xml non trovato)"
    fi

    # Write tracker: src/main/resources/module/<key>/module.json
    # api.routes is updated to reflect the actual installed package (REGISTER_CALL)
    mkdir -p "$TRACKER_DIR"
    cp "$MODULE_DIR/module.json" "$TRACKER_DIR/module.json"
    if [ -n "$REGISTER_CALL" ]; then
        python3 -c "
import json
path = '$TRACKER_DIR/module.json'
with open(path) as f:
    m = json.load(f)
if 'api' not in m or m['api'] is None:
    m['api'] = {}
m['api']['routes'] = '$REGISTER_CALL'
with open(path, 'w') as f:
    json.dump(m, f, indent=2)
    f.write('\n')
" 2>/dev/null || true
    fi
    success "  Tracker scritto: ${TRACKER_DIR#$WORKSPACE/}/module.json"
    _module_manifest_update

    printf '\n'
    success "Installazione modulo '$MODULE' completata"

    # Show install_notice if present
    python3 -c "
import json
with open('$MODULE_DIR/module.json') as f:
    m = json.load(f)
notice = m.get('install_notice', '')
if notice:
    print()
    print('  NOTA: ' + notice)
" 2>/dev/null || true

    # Touch App.java so that cmd app run (inotifywait watch) triggers a full
    # recompile *after* all module files are on disk. Without this, inotifywait
    # may wake up on the first created directory, compile an incomplete source
    # tree, and then miss all subsequent file events inside new subdirectories
    # (inotifywait does not watch directories created after it starts).
    touch "$WORKSPACE/src/main/java/dev/jms/app/App.java" 2>/dev/null || true

    # Execute post-install script if present.
    # The script runs AFTER the touch so that if cmd app run is active the
    # recompile+restart cycle is already triggered. We then wait for the backend
    # to become reachable before running the script, so that any API calls it
    # makes find the new module already loaded.
    local INSTALL_SCRIPT
    INSTALL_SCRIPT=$(python3 -c "
import json
with open('$MODULE_DIR/module.json') as f:
    m = json.load(f)
print(m.get('install_script', ''))
" 2>/dev/null || echo "")

    if [ -n "$INSTALL_SCRIPT" ] && [ -f "$MODULE_DIR/$INSTALL_SCRIPT" ]; then
        local PORT="${API_PORT:-8080}"
        if app_is_running; then
            info "[module] Backend in esecuzione — attendo riavvio con il nuovo modulo..."
            local i=0
            # Step 1: wait for the port to go DOWN (JVM restarting after recompile).
            # Cap at 10 s — if cmd app run is not active the port never drops.
            while [ $i -lt 20 ]; do
                (echo > /dev/tcp/localhost/$PORT) 2>/dev/null || break
                sleep 0.5
                i=$((i+1))
            done
            # Step 2: wait for the port to come back UP (new binary loaded).
            i=0
            while [ $i -lt 120 ]; do
                (echo > /dev/tcp/localhost/$PORT) 2>/dev/null && break
                sleep 0.5
                i=$((i+1))
            done
            if ! (echo > /dev/tcp/localhost/$PORT) 2>/dev/null; then
                warn "[module] Backend non raggiungibile dopo 60s — esegui manualmente lo script di post-install:"
                warn "         bash $MODULE_DIR/$INSTALL_SCRIPT $WORKSPACE $MODULE_KEY"
            else
                info "[module] Esecuzione script di post-install: $INSTALL_SCRIPT"
                if bash "$MODULE_DIR/$INSTALL_SCRIPT" "$WORKSPACE" "$MODULE_KEY"; then
                    success "  Script di post-install completato"
                else
                    warn "  Script di post-install fallito (exit code: $?)"
                    warn "  L'installazione del modulo continua comunque"
                fi
            fi
        else
            info "[module] Esecuzione script di post-install: $INSTALL_SCRIPT"
            if bash "$MODULE_DIR/$INSTALL_SCRIPT" "$WORKSPACE" "$MODULE_KEY"; then
                success "  Script di post-install completato"
            else
                warn "  Script di post-install fallito (exit code: $?)"
                warn "  L'installazione del modulo continua comunque"
            fi
        fi
    fi

    printf '\n'
    printf 'Prossimi passi:\n'
    printf '  1. cmd app build (compila frontend + backend)\n\n'
}

# ============================================================================
# module_install — accetta archivio .tar.gz oppure cartella già estratta
#
# Il path è relativo a module/ e può includere namespace (es. cti/vonage).
# ============================================================================

module_install() {
    local INPUT=""
    local FORCE=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --force) FORCE=true; shift ;;
            -*) error "Opzione sconosciuta: $1. Usage: cmd module install <path> [--force]" ;;
            *) INPUT="$1"; shift ;;
        esac
    done
    [ -n "$INPUT" ] || error "Usage: cmd module install <path> [--force]"

    # Normalizza: rimuovi slash iniziale/finale
    local REL_PATH="${INPUT#/}"
    REL_PATH="${REL_PATH%/}"

    local ABS_INPUT="$WORKSPACE/jms/module/$REL_PATH"

    local MODULE_DIR
    local TMP_DIR=""
    local MODULE_KEY

    if [ -f "$ABS_INPUT" ]; then
        # Archivio .tar.gz: estrai in cartella temporanea
        TMP_DIR=$(mktemp -d)
        tar -xzf "$ABS_INPUT" -C "$TMP_DIR" --warning=no-unknown-keyword 2>/dev/null || \
            tar -xzf "$ABS_INPUT" -C "$TMP_DIR"
        MODULE_DIR="$TMP_DIR"
        # Ricava MODULE_KEY: directory del path + nome dal module.json
        local DIR_PART
        DIR_PART=$(dirname "$REL_PATH")
        local MOD_NAME
        MOD_NAME=$(python3 -c "import json; print(json.load(open('$MODULE_DIR/module.json'))['name'])" 2>/dev/null || true)
        if [ "$DIR_PART" = "." ]; then
            MODULE_KEY="$MOD_NAME"
        else
            MODULE_KEY="$DIR_PART/$MOD_NAME"
        fi
    elif [ -d "$ABS_INPUT" ]; then
        MODULE_DIR="$ABS_INPUT"
        MODULE_KEY="$REL_PATH"
    else
        error "Non trovato (né archivio né cartella): $ABS_INPUT"
    fi

    [ -f "$MODULE_DIR/module.json" ] || error "module.json non trovato in: $MODULE_DIR"

    local MODULE
    MODULE=$(python3 -c "import json; print(json.load(open('$MODULE_DIR/module.json'))['name'])" 2>/dev/null)
    [ -n "$MODULE" ] || error "Impossibile leggere 'name' da module.json"

    # Verifica dipendenze transitive (risoluzione ricorsiva via tracker installati)
    local MISSING_DEPS
    MISSING_DEPS=$(python3 -c "
import json, os, sys

tracker_base = os.path.join('$WORKSPACE', 'src', 'main', 'resources', 'module')

def find_tracker(name):
    for root, dirs, files in os.walk(tracker_base):
        for f in files:
            if f == 'module.json':
                path = os.path.join(root, f)
                try:
                    m = json.load(open(path))
                    if m.get('name') == name:
                        return path
                except Exception:
                    pass
    return None

def collect_missing(json_path, visited=None, missing=None):
    if visited is None:
        visited = set()
    if missing is None:
        missing = []
    try:
        m = json.load(open(json_path))
    except Exception:
        return missing
    for dep_name in m.get('dependencies', {}).keys():
        if dep_name in visited:
            continue
        visited.add(dep_name)
        tracker_path = find_tracker(dep_name)
        if tracker_path is None:
            missing.append(dep_name)
        else:
            collect_missing(tracker_path, visited, missing)
    return missing

for dep in collect_missing('$MODULE_DIR/module.json'):
    print(dep)
" 2>/dev/null)

    local DEP_COUNT
    DEP_COUNT=$(python3 -c "
import json
with open('$MODULE_DIR/module.json') as f:
    m = json.load(f)
print(len(m.get('dependencies', {})))
" 2>/dev/null || echo "0")

    if [ -n "$MISSING_DEPS" ]; then
        printf '\n'
        warn "Il modulo '$MODULE' richiede le seguenti dipendenze non installate:"
        while IFS= read -r dep; do
            printf "    - %s\n" "$dep"
        done <<< "$MISSING_DEPS"
        printf '\n'
        if [ "$FORCE" = true ]; then
            warn "  Installazione forzata con --force"
        else
            if [ -n "$TMP_DIR" ]; then rm -rf "$TMP_DIR"; fi
            error "Installa prima i moduli mancanti con: cmd module install <modulo>"
        fi
    elif [ "$DEP_COUNT" -gt 0 ]; then
        success "Tutte le dipendenze sono soddisfatte"
    fi

    _module_install "$MODULE_DIR" "$MODULE_KEY"

    if [ -n "$TMP_DIR" ]; then rm -rf "$TMP_DIR"; fi
}

# ============================================================================
# module_export — esporta in cartella module/<key>[-version]/
#
# --name accetta sia nomi semplici ("user") sia key con namespace ("cti/vonage").
# ============================================================================

module_export() {
    local MODULE_KEY=""
    local VERSION=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --name)
                [ -n "$2" ] || error "--name richiede un valore"
                MODULE_KEY="$2"; shift 2 ;;
            --vers|--version|-v)
                [ -n "$2" ] || error "--vers richiede un valore (es. 1.2.3)"
                VERSION="$2"; shift 2 ;;
            -*) error "Opzione sconosciuta: $1. Usage: cmd module export --name <key> [--vers 1.2.3]" ;;
            *) error "Usage: cmd module export --name <key> [--vers 1.2.3]" ;;
        esac
    done

    [ -n "$MODULE_KEY" ] || error "Usage: cmd module export --name <key> [--vers 1.2.3]"
    MODULE_KEY="${MODULE_KEY%/}"

    local MODULE_NAME MODULE_NS JAVA_DIR GUI_DIR JAVA_PKG GUI_PATH TRACKER_DIR
    _module_paths "$MODULE_KEY"

    [ -d "$JAVA_DIR" ] || [ -d "$GUI_DIR" ] || \
        error "Nessuna sorgente Java o GUI trovata per il modulo '$MODULE_KEY'"

    local MIGRATION_DIR="$WORKSPACE/src/main/resources/db/migration"

    # Output: module/<ns>/name[-version]/ oppure module/name[-version]/
    local FOLDER_NAME
    if [ -n "$VERSION" ]; then
        FOLDER_NAME="${MODULE_NAME}-${VERSION}"
    else
        FOLDER_NAME="$MODULE_NAME"
    fi
    local OUTPUT
    if [ -n "$MODULE_NS" ]; then
        OUTPUT="$WORKSPACE/jms/module/$MODULE_NS/$FOLDER_NAME"
    else
        OUTPUT="$WORKSPACE/jms/module/$FOLDER_NAME"
    fi

    if [ -d "$OUTPUT" ]; then
        warn "La cartella '$OUTPUT' esiste già — verrà sovrascritta"
        rm -rf "$OUTPUT"
    fi
    mkdir -p "$OUTPUT"

    # Java sources
    if [ -d "$JAVA_DIR" ]; then
        info "[module] Copio sorgenti Java ($JAVA_DIR)..."
        mkdir -p "$OUTPUT/api"
        cp -r "$JAVA_DIR/." "$OUTPUT/api/"
    fi

    # GUI sources
    if [ -d "$GUI_DIR" ]; then
        info "[module] Copio sorgenti GUI ($GUI_DIR)..."
        mkdir -p "$OUTPUT/gui"
        cp -r "$GUI_DIR/." "$OUTPUT/gui/"
    else
        warn "[module] Nessuna sorgente GUI trovata per il modulo '$MODULE_KEY'"
    fi

    # Migration files (matched by MODULE_NAME in filename)
    local HAS_MIGRATIONS=false
    while IFS= read -r -d '' f; do
        if [ "$HAS_MIGRATIONS" = false ]; then
            mkdir -p "$OUTPUT/migration"
            info "[module] Copio migration..."
        fi
        cp "$f" "$OUTPUT/migration/"
        HAS_MIGRATIONS=true
    done < <(find "$MIGRATION_DIR" -maxdepth 1 -name "*__${MODULE_NAME}*.sql" -print0 2>/dev/null)

    [ "$HAS_MIGRATIONS" = true ] || warn "[module] Nessuna migration trovata per il modulo '$MODULE_NAME'"

    # CLI scripts
    local SRC_CLI_DIR="$WORKSPACE/jms/module/$MODULE_KEY/cli"
    if [ -d "$SRC_CLI_DIR" ]; then
        info "[module] Copio script CLI..."
        mkdir -p "$OUTPUT/cli"
        cp -r "$SRC_CLI_DIR/." "$OUTPUT/cli/"
    fi

    # Maven profile extraction (il marker usa key con / sostituito da -)
    local PROFILE_MARKER="${MODULE_KEY//\//-}"
    local POM="$WORKSPACE/pom.xml"
    if [ -f "$POM" ]; then
        info "[module] Estraggo Maven profile dal pom.xml..."

        awk -v mod="$PROFILE_MARKER" '
            /<!-- \[MODULE:/ {
                if ($0 ~ "\\[MODULE:" mod "\\]") {
                    found=1
                }
            }
            found {print}
            /<!-- \[\/MODULE:/ {
                if ($0 ~ "\\[/MODULE:" mod "\\]") {
                    exit
                }
            }
        ' "$POM" > "$OUTPUT/profile.xml"

        if [ -s "$OUTPUT/profile.xml" ]; then
            success "  Maven profile esportato"
        else
            rm -f "$OUTPUT/profile.xml"
            warn "  Nessun Maven profile trovato per il modulo '$MODULE_KEY'"
        fi
    fi

    # Generate module.json automatically
    info "[module] Genero module.json..."

    # Preserve existing dependencies and install_notice from tracker
    local EXISTING_DEPS="{}"
    local EXISTING_NOTICE=""
    if [ -f "$TRACKER_DIR/module.json" ]; then
        EXISTING_DEPS=$(python3 -c "
import json
with open('$TRACKER_DIR/module.json') as f:
    m = json.load(f)
print(json.dumps(m.get('dependencies', {}), indent=4))
" 2>/dev/null || echo "{}")
        EXISTING_NOTICE=$(python3 -c "
import json
with open('$TRACKER_DIR/module.json') as f:
    m = json.load(f)
v = m.get('install_notice')
print(v if v else '')
" 2>/dev/null || true)
    fi

    # Build api.routes from JAVA_PKG + Routes.java signature
    local API_JSON="null"
    if [ -d "$JAVA_DIR" ]; then
        local ROUTES_FILE="$JAVA_DIR/Routes.java"
        if [ -f "$ROUTES_FILE" ]; then
            local REGISTER_CALL="${JAVA_PKG}.Routes.register(router);"
            if grep -q 'Config config' "$ROUTES_FILE" 2>/dev/null; then
                REGISTER_CALL="${JAVA_PKG}.Routes.register(router, config);"
            fi
            API_JSON=$(python3 -c "
import json
routes = '${REGISTER_CALL}'
api_cfg = {}
props_file = '$WORKSPACE/config/application.properties'
try:
    with open(props_file) as f:
        for line in f:
            line = line.strip()
            if line.startswith('#') or '=' not in line:
                continue
            key, _, val = line.partition('=')
            key = key.strip()
            if key.startswith('${MODULE_NAME}.'):
                api_cfg[key] = val.strip()
except Exception:
    pass
data = {'routes': routes, 'config': api_cfg}
print(json.dumps(data, indent=4))
" 2>/dev/null || echo "null")
        fi
    fi

    # Extract config.js entry for this module
    local CONFIG_JS_ENTRY="null"
    local CONFIG_JS="$WORKSPACE/gui/src/config.js"
    if [ -f "$CONFIG_JS" ]; then
        CONFIG_JS_ENTRY=$(python3 -c "
import re, json, sys

with open('$CONFIG_JS') as f:
    content = f.read()

pattern = r'\b${MODULE_NAME}\s*:\s*\{'
m = re.search(pattern, content)
if not m:
    print('null')
    sys.exit(0)

start = m.end() - 1
depth = 0
i = start
while i < len(content):
    if content[i] == '{':
        depth += 1
    elif content[i] == '}':
        depth -= 1
        if depth == 0:
            break
    i += 1

block = content[start:i+1]
inner = block[1:-1]
result = {}
for line in inner.splitlines():
    line = line.strip().rstrip(',')
    if not line or line.startswith('//'):
        continue
    colon = line.find(':')
    if colon < 0:
        continue
    key = line[:colon].strip()
    val_str = line[colon+1:].strip()
    if val_str == 'null':
        result[key] = None
    elif val_str == 'true':
        result[key] = True
    elif val_str == 'false':
        result[key] = False
    elif val_str.isdigit():
        result[key] = int(val_str)
    elif val_str.startswith('{') and val_str.endswith('}'):
        try:
            import re as _re
            js_obj = val_str
            js_obj = _re.sub(r'([{,]\s*)([a-zA-Z_][a-zA-Z0-9_]*)\s*:', r'\1\"\2\":', js_obj)
            js_obj = js_obj.replace(\"'\", '\"')
            result[key] = json.loads(js_obj)
        except Exception:
            result[key] = val_str
    elif val_str.startswith('(') or val_str.startswith('()'):
        result[key] = '__LAMBDA__:' + val_str
    else:
        result[key] = val_str.strip(\"'\\\"\" )

print(json.dumps(result, indent=4))
" 2>/dev/null || echo "null")
    fi

    python3 -c "
import json, sys

deps_str    = '''$EXISTING_DEPS'''
api_str     = '''$API_JSON'''
config_str  = '''$CONFIG_JS_ENTRY'''
notice      = '''$EXISTING_NOTICE'''

try:
    deps = json.loads(deps_str)
except Exception:
    deps = {}
try:
    api = json.loads(api_str)
except Exception:
    api = None
try:
    cfg = json.loads(config_str)
except Exception:
    cfg = None

import os
install_script   = 'cli/install.sh'   if os.path.isfile('$OUTPUT/cli/install.sh')   else None
uninstall_script = 'cli/uninstall.sh' if os.path.isfile('$OUTPUT/cli/uninstall.sh') else None

module_data = {
    'name': '$MODULE_NAME',
    'version': '${VERSION:-dev}',
    'dependencies': deps,
    'api': api,
    'gui': {'config': cfg},
    'install_script': install_script,
    'uninstall_script': uninstall_script,
    'install_notice': notice.strip() if notice.strip() else None
}
with open('$OUTPUT/module.json', 'w') as f:
    json.dump(module_data, f, indent=4)
    f.write('\n')
print('OK')
" 2>/dev/null && success "[module] module.json generato" \
    || warn "[module] Impossibile generare module.json automaticamente"

    success "Modulo '$MODULE_KEY' esportato → $OUTPUT"
}

# ============================================================================
# module_dist — comprime una cartella di modulo in archivio .tar.gz
# ============================================================================

module_dist() {
    local REL_PATH="$1"
    [ -n "$REL_PATH" ] || error "Usage: cmd module dist <path>"

    local SRC="$WORKSPACE/jms/module/$REL_PATH"
    [ -d "$SRC" ] || error "Cartella non trovata: $SRC"
    [ -f "$SRC/module.json" ] || error "module.json non trovato in: $SRC"

    local NAME VERSION
    NAME=$(python3 -c "import json; print(json.load(open('$SRC/module.json'))['name'])" 2>/dev/null)
    VERSION=$(python3 -c "import json; print(json.load(open('$SRC/module.json'))['version'])" 2>/dev/null)
    [ -n "$NAME" ]    || error "Impossibile leggere 'name' da module.json"
    [ -n "$VERSION" ] || error "Impossibile leggere 'version' da module.json"

    local DIST_DIR="$WORKSPACE/dist"
    mkdir -p "$DIST_DIR"

    local OUTPUT="$DIST_DIR/${NAME}-${VERSION}.tar.gz"
    COPYFILE_DISABLE=1 tar -czf "$OUTPUT" -C "$SRC" .
    success "Archivio creato → $OUTPUT"
}

# ============================================================================
# module_remove — rimuove un modulo installato leggendo il tracker
#
# --name accetta sia nomi semplici ("user") sia key con namespace ("cti/vonage").
# ============================================================================

module_remove() {
    local MODULE_KEY=""
    local FORCE=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --name)
                [ -n "$2" ] || error "--name richiede un valore"
                MODULE_KEY="$2"; shift 2 ;;
            --force) FORCE=true; shift ;;
            -*) error "Opzione sconosciuta: $1. Usage: cmd module uninstall --name <key> [--force]" ;;
            *) error "Usage: cmd module uninstall --name <key> [--force]" ;;
        esac
    done

    [ -n "$MODULE_KEY" ] || error "Usage: cmd module uninstall --name <key> [--force]"
    MODULE_KEY="${MODULE_KEY%/}"

    local MODULE_NAME MODULE_NS JAVA_DIR GUI_DIR JAVA_PKG GUI_PATH TRACKER_DIR
    _module_paths "$MODULE_KEY"

    [ -f "$TRACKER_DIR/module.json" ] || \
        error "Modulo '$MODULE_KEY' non risulta installato (tracker non trovato: $TRACKER_DIR/module.json)"

    local MODULE
    MODULE=$(python3 -c "import json; print(json.load(open('$TRACKER_DIR/module.json'))['name'])" 2>/dev/null || echo "$MODULE_NAME")

    # Verifica dipendenze inverse: blocca se altri moduli installati dipendono da questo
    local DEPENDENTS
    DEPENDENTS=$(python3 -c "
import json, os

tracker_base = os.path.join('$WORKSPACE', 'src', 'main', 'resources', 'module')
target = '$MODULE_NAME'

for root, dirs, files in os.walk(tracker_base):
    for f in files:
        if f != 'module.json':
            continue
        path = os.path.join(root, f)
        # Salta il tracker del modulo che stiamo rimuovendo
        if os.path.normpath(os.path.dirname(path)) == os.path.normpath('$TRACKER_DIR'):
            continue
        try:
            m = json.load(open(path))
            if target in m.get('dependencies', {}):
                print(m.get('name', os.path.dirname(path)))
        except Exception:
            pass
" 2>/dev/null)

    if [ -n "$DEPENDENTS" ]; then
        printf '\n'
        warn "I seguenti moduli installati dipendono da '$MODULE_NAME':"
        while IFS= read -r dep; do
            printf "    - %s\n" "$dep"
        done <<< "$DEPENDENTS"
        printf '\n'
        if [ "$FORCE" = true ]; then
            warn "  Rimozione forzata con --force"
        else
            error "Rimozione bloccata. Rimuovi prima i moduli dipendenti o usa --force per forzare."
        fi
    fi

    if ! confirm "Rimuovere il modulo '$MODULE_KEY'?"; then
        info "Operazione annullata"
        return 0
    fi

    printf '\n'
    info "[module] Rimozione modulo: $MODULE_KEY"
    printf '\n'

    # Execute pre-remove script if present
    local UNINSTALL_SCRIPT
    UNINSTALL_SCRIPT=$(python3 -c "
import json
with open('$TRACKER_DIR/module.json') as f:
    m = json.load(f)
print(m.get('uninstall_script', ''))
" 2>/dev/null || echo "")

    if [ -n "$UNINSTALL_SCRIPT" ]; then
        # Try to find the script in the original module directory
        local SCRIPT_PATH=""
        if [ -d "$WORKSPACE/jms/module/$MODULE_KEY" ] && [ -f "$WORKSPACE/jms/module/$MODULE_KEY/$UNINSTALL_SCRIPT" ]; then
            SCRIPT_PATH="$WORKSPACE/jms/module/$MODULE_KEY/$UNINSTALL_SCRIPT"
        fi

        if [ -n "$SCRIPT_PATH" ]; then
            info "[module] Esecuzione script di pre-remove: $UNINSTALL_SCRIPT"
            if bash "$SCRIPT_PATH" "$WORKSPACE" "$MODULE_KEY"; then
                success "  Script di pre-remove completato"
            else
                warn "  Script di pre-remove fallito (exit code: $?)"
                warn "  La rimozione del modulo continua comunque"
            fi
        else
            warn "  Script di pre-remove non trovato: $UNINSTALL_SCRIPT"
        fi
    fi

    # Java sources
    local JAVA_MODULE_DIR="$WORKSPACE/src/main/java/dev/jms/app/module"
    if [ -d "$JAVA_DIR" ]; then
        rm -rf "$JAVA_DIR"
        success "  Sorgenti Java rimossi: ${JAVA_DIR#$WORKSPACE/}"
        if [ -n "$MODULE_NS" ]; then
            local JAVA_NS_DIR="$JAVA_MODULE_DIR/$MODULE_NS"
            if [ -d "$JAVA_NS_DIR" ] && [ -z "$(ls -A "$JAVA_NS_DIR")" ]; then
                rm -rf "$JAVA_NS_DIR"
            fi
        fi
        if [ -d "$JAVA_MODULE_DIR" ] && [ -z "$(ls -A "$JAVA_MODULE_DIR")" ]; then
            rm -rf "$JAVA_MODULE_DIR"
        fi
    fi

    # GUI sources
    if [ -d "$GUI_DIR" ]; then
        rm -rf "$GUI_DIR"
        success "  Sorgenti GUI rimossi: ${GUI_DIR#$WORKSPACE/}"
        if [ -n "$MODULE_NS" ]; then
            local GUI_NS_DIR="$WORKSPACE/gui/src/module/$MODULE_NS"
            if [ -d "$GUI_NS_DIR" ] && [ -z "$(ls -A "$GUI_NS_DIR")" ]; then
                rm -rf "$GUI_NS_DIR"
            fi
        fi
    fi

    # Remove route from App.java
    local APP_JAVA="$WORKSPACE/src/main/java/dev/jms/app/App.java"
    if [ -f "$APP_JAVA" ]; then
        local REGISTER_CALL
        REGISTER_CALL=$(python3 -c "
import json
with open('$TRACKER_DIR/module.json') as f:
    m = json.load(f)
api = m.get('api')
if api:
    print(api.get('routes', ''))
" 2>/dev/null || true)
        if [ -n "$REGISTER_CALL" ]; then
            if grep -qF "$REGISTER_CALL" "$APP_JAVA"; then
                python3 -c "
with open('$APP_JAVA') as f:
    lines = f.readlines()
call = '${REGISTER_CALL}'.strip()
lines = [l for l in lines if call not in l]
with open('$APP_JAVA', 'w') as f:
    f.writelines(lines)
" 2>/dev/null && success "  Route rimossa da App.java" || warn "  Impossibile rimuovere route da App.java"
            fi
        fi
    fi

    # Remove entry from config.js (by module name)
    local CONFIG_JS="$WORKSPACE/gui/src/config.js"
    if [ -f "$CONFIG_JS" ]; then
        python3 -c "
import re, sys

with open('$CONFIG_JS') as f:
    content = f.read()

pattern = r'(\n\s+${MODULE}\s*:\s*\{)'
m = re.search(pattern, content)
if not m:
    sys.exit(0)

start = m.start(1)
brace_start = content.index('{', m.start(1))
depth = 0
i = brace_start
while i < len(content):
    if content[i] == '{':
        depth += 1
    elif content[i] == '}':
        depth -= 1
        if depth == 0:
            break
    i += 1

end = i + 1
if end < len(content) and content[end] == ',':
    end += 1

content = content[:start] + content[end:]
with open('$CONFIG_JS', 'w') as f:
    f.write(content)
print('OK')
" 2>/dev/null && success "  Modulo rimosso da config.js" || warn "  Impossibile rimuovere da config.js — rimuovi manualmente '$MODULE'"
    fi

    # Remove Maven profile from pom.xml (usa marker con / → -)
    local POM="$WORKSPACE/pom.xml"
    local PROFILE_MARKER="${MODULE_KEY//\//-}"
    if [ -f "$POM" ]; then
        info "[module] Rimuovo Maven profile dal pom.xml..."

        awk -v mod="$PROFILE_MARKER" '
            /<!-- \[MODULE:/ {
                if ($0 ~ "\\[MODULE:" mod "\\]") {
                    skip=1
                }
            }
            !skip {print}
            /<!-- \[\/MODULE:/ {
                if ($0 ~ "\\[/MODULE:" mod "\\]") {
                    skip=0
                    next
                }
            }
        ' "$POM" > "$POM.tmp" && mv "$POM.tmp" "$POM"

        success "  Maven profile rimosso dal pom.xml"
    fi

    # Migration files: warn only (Flyway state cannot be rolled back automatically)
    local MIGRATION_DIR="$WORKSPACE/src/main/resources/db/migration"
    local MIGR_FILES
    MIGR_FILES=$(find "$MIGRATION_DIR" -maxdepth 1 -name "*__${MODULE_NAME}*.sql" 2>/dev/null | sort)
    if [ -n "$MIGR_FILES" ]; then
        warn "  Le seguenti migration NON vengono rimosse automaticamente (Flyway):"
        echo "$MIGR_FILES" | while IFS= read -r f; do warn "    $(basename "$f")"; done
        warn "  Esegui 'cmd db reset' se vuoi ripristinare il database da zero"
    fi

    # Remove module config properties from application.properties and .env
    local PROP_MARKER="${MODULE_KEY//\//-}"
    local APP_PROPS="$WORKSPACE/config/application.properties"
    if grep -qF "# [MODULE:${PROP_MARKER}]" "$APP_PROPS" 2>/dev/null; then
        python3 -c "
import re, sys
content = open('$APP_PROPS').read()
content = re.sub(r'\n?# \[MODULE:${PROP_MARKER}\].*?# \[/MODULE:${PROP_MARKER}\]\n?', '\n', content, flags=re.DOTALL)
open('$APP_PROPS', 'w').write(content)
"
        success "  Proprietà rimosse da config/application.properties"
    fi
    local ENV_FILE="$WORKSPACE/.env"
    if grep -qF "# [MODULE:${PROP_MARKER}]" "$ENV_FILE" 2>/dev/null; then
        python3 -c "
import re, sys
content = open('$ENV_FILE').read()
content = re.sub(r'\n?# \[MODULE:${PROP_MARKER}\].*?# \[/MODULE:${PROP_MARKER}\]\n?', '\n', content, flags=re.DOTALL)
open('$ENV_FILE', 'w').write(content)
"
        success "  Variabili rimosse da .env"
    fi

    # Remove tracker
    rm -rf "$TRACKER_DIR"
    success "  Tracker rimosso"
    if [ -n "$MODULE_NS" ]; then
        local TRACKER_NS_DIR="$WORKSPACE/src/main/resources/module/$MODULE_NS"
        if [ -d "$TRACKER_NS_DIR" ] && [ -z "$(ls -A "$TRACKER_NS_DIR")" ]; then
            rm -rf "$TRACKER_NS_DIR"
        fi
    fi

    _module_manifest_update

    # Touch App.java so that cmd app run (inotifywait watch) triggers a recompile
    # after all module files have been removed from disk.
    touch "$WORKSPACE/src/main/java/dev/jms/app/App.java" 2>/dev/null || true

    printf '\n'
    success "Modulo '$MODULE_KEY' rimosso"
}

# ============================================================================
# module_cli — esegue uno script CLI di un modulo o lista gli script disponibili
#
# Formato: cmd module cli <module_name> <script> [OPTIONS]
# Formato: cmd module cli <module_name> list
# Risolve in: module/<module_name>/cli/<script>.sh [OPTIONS]
# ============================================================================

module_cli() {
    local MODULE_NAME="$1"
    local COMMAND="$2"
    shift 2 2>/dev/null || true

    [ -n "$MODULE_NAME" ]  || error "Usage: cmd module cli <module_name> <script|list> [OPTIONS]"
    [ -n "$COMMAND" ]  || error "Usage: cmd module cli <module_name> <script|list> [OPTIONS]"

    local CLI_DIR="$WORKSPACE/jms/module/${MODULE_NAME}/cli"

    # Subcommand: list
    if [ "$COMMAND" = "list" ]; then
        if [ ! -d "$CLI_DIR" ]; then
            echo "No CLI commands available for module '$MODULE_NAME'"
            return 0
        fi

        local SCRIPTS
        SCRIPTS=$(find "$CLI_DIR" -maxdepth 1 -type f -name "*.sh" 2>/dev/null | sort)

        if [ -z "$SCRIPTS" ]; then
            echo "No CLI commands available for module '$MODULE_NAME'"
            return 0
        fi

        echo "Available CLI commands for module '$MODULE_NAME':"
        echo "$SCRIPTS" | while read -r SCRIPT; do
            local BASENAME
            BASENAME=$(basename "$SCRIPT" .sh)
            echo "  - $BASENAME"
        done
        return 0
    fi

    # Comportamento originale: esegui lo script
    local SCRIPT="$CLI_DIR/${COMMAND}.sh"
    [ -f "$SCRIPT" ] || error "Script not found: module/${MODULE_NAME}/cli/${COMMAND}.sh"

    bash "$SCRIPT" "$@"
}


