{
    "name": "user",
    "version": "1.0.0",
    "dependencies": {
        "audit": "*"
    },
    "api": {
        "routes": "dev.jms.app.module.user.Routes.register(router, config);",
        "config": {
            "user.cookie.secure": "false",
            "user.cookie.samesite": "Lax",
            "user.ratelimit.max.attempts": "5",
            "user.ratelimit.window.seconds": "300"
        }
    },
    "gui": {
        "config": {
            "route": "/user",
            "path": "user",
            "container": "main",
            "authorization": null,
            "persistent": false,
            "priority": 999,
            "init": true
        }
    },
    "install_script": null,
    "install_notice": "Gli account di bootstrap (root/root123., admin/admin123., operator/operator123.) vengono creati dalla migration. Cambiare le password dopo la prima installazione."
}
