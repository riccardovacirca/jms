{
    "name": "user",
    "version": "1.0.0",
    "dependencies": {
        "audit": "*"
    },
    "api": {
        "routes": "dev.jms.app.module.user.Routes.register(router, config);",
        "config": {
            "user.cookie.secure": "false",
            "user.cookie.samesite": "Lax",
            "user.ratelimit.max.attempts": "5",
            "user.ratelimit.window.seconds": "300"
        }
    },
    "gui": {
        "config": {
            "route": "/user",
            "path": "user",
            "container": "main",
            "authorization": null,
            "persistent": false,
            "priority": 999,
            "init": true
        }
    },
    "install_notice": "Per creare l'account root, chiamare POST /api/user/root con body JSON: {\"password\": \"...\", \"email\": \"...\"}. L'utente root avrà username fisso 'root' e ruolo admin con tutti i privilegi."
}
