{
    "name": "crm",
    "version": "1.0.0",
    "dependencies": {
        "user": "^1.0.0",
        "vonage": "*"
    },
    "api": {
        "routes": "dev.jms.app.module.crm.Routes.register(router, config);",
        "config": {
            "crm.resources.tmp": "/app/storage/crm/tmp"
        }
    },
    "gui": {
        "config": {
            "route": "/crm",
            "path": "crm",
            "container": "main",
            "authorization": {
                "redirectTo": "/user"
            },
            "persistent": false,
            "priority": 999,
            "init": true
        }
    },
    "install_notice": null
}
